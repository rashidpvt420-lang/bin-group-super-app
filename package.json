{
  "name": "bin-group-platform",
  "private": true,
  "description": "Consolidated BIN Group Property Management Ecosystem",
  "workspaces": [
    "apps/*",
    "packages/*",
    "functions"
  ],
  "scripts": {
    "build": "npm run build -ws",
    "deploy": "powershell ./deploy-production.ps1",
    "clean": "npm run clean -ws && rm -rf hosting/public/*",
    "lint": "npm run lint -ws --if-present"
  },
  "devDependencies": {
    "firebase-tools": "^13.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.9",
    "firebase": "^10.14.1",
    "lucide-react": "^1.7.0"
  }
}
