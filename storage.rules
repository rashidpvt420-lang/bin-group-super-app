rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
  
    // Helper: Is Authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: Role Verification (Sovereign Role Protocol)
    function hasRole(role) {
      return isAuth() && request.auth.token.role == role;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.admin == true || 
        request.auth.token.isAdmin == true ||
        request.auth.token.ceo == true ||
        request.auth.token.manager == true ||
        request.auth.token.role in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin', 'ADMIN', 'SUPER_ADMIN', 'CEO', 'MANAGER']
      );
    }

    function isAuditor() {
      return hasRole('AUDITOR') || hasRole('compliance_officer');
    }

    // ─── KYC & IDENTITY VAULT ──────────────────────────────────────────────
    match /kyc_documents/{documentId} {
      allow write: if isAuth() && request.resource.size < 15 * 1024 * 1024;
      allow read: if isAuth() && (documentId.matches(request.auth.uid + '.*') || isAdmin() || isAuditor());
    }

    match /temp_kyc/{documentId} {
      allow write: if isAuth() && request.resource.size < 15 * 1024 * 1024;
      allow read: if isAuth();
    }

    match /kyc/{userId}/{allPaths=**} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin() || isAuditor());
      allow write: if isAuth() && (request.auth.uid == userId) && 
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('application/pdf|image/.*');
    }

    match /onboarding-proof/{userId}/{intakeId}/{fileName} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin() || isAuditor());
      allow write: if isAuth() && request.auth.uid == userId &&
                   request.resource.size < 15 * 1024 * 1024 &&
                   request.resource.contentType.matches('application/pdf|image/.*');
    }

    // ─── TRANSACTIONAL ASSETS (Property & Contracts) ─────────────────────────
    match /property_images/{documentId} {
      allow read: if true; 
      allow write: if isAuth() && request.resource.size < 15 * 1024 * 1024;
    }
    
    match /contracts/{documentId} {
      allow write: if isAdmin(); // Only Admin can upload signed institutional contracts
      allow read: if isAuth() && (documentId.matches(request.auth.uid + '.*') || isAdmin() || isAuditor());
    }

    // ─── OPERATIONAL ASSETS (Work Orders & Evidence) ─────────────────────────
    match /workOrders/{orderId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && (hasRole('TECHNICIAN') || hasRole('technician') || isAdmin());
    }

    // ─── FIELD EVIDENCE VAULT ──────────────────────────────────────────────
    match /evidence_photos/{ticketId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && (hasRole('TECHNICIAN') || hasRole('technician') || isAdmin()) &&
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
    }

    // ─── PUBLIC INFRASTRUCTURE ──────────────────────────────────────────────
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ─── DESIGN STUDIO REFERENCE IMAGES ──────────────────────────────────────────
    match /design_requests/{userId}/{allPaths=**} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuth() && (request.auth.uid == userId) && 
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
    }

    // Default lockdown for unmanaged paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
