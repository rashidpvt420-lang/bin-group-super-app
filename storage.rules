rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
  
    function isAuth() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuth() && request.auth.token.role == role;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.admin == true || 
        request.auth.token.isAdmin == true ||
        request.auth.token.ceo == true ||
        request.auth.token.manager == true ||
        request.auth.token.role in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin', 'ADMIN', 'SUPER_ADMIN', 'CEO', 'MANAGER']
      );
    }

    function isAuditor() {
      return hasRole('AUDITOR') || hasRole('compliance_officer');
    }

    function isTenantRole() {
      return hasRole('tenant') || hasRole('TENANT');
    }

    function isTechnicianRole() {
      return hasRole('technician') || hasRole('TECHNICIAN');
    }

    function isOwnerRole() {
      return hasRole('owner') || hasRole('OWNER');
    }

    function isImageUpload(maxSizeMb) {
      return request.resource != null &&
             request.resource.size < maxSizeMb * 1024 * 1024 &&
             request.resource.contentType.matches('image/.*');
    }

    // Tenant issue photos uploaded by TenantRequestPage.tsx:
    // maintenanceTickets/{tenantUid}/{timestamp}_{fileName}
    match /maintenanceTickets/{tenantId}/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == tenantId && isImageUpload(10);
    }

    // Technician/admin job completion evidence for maintenance tickets.
    match /maintenanceTickets/{ticketId}/proofs/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth() && (isTechnicianRole() || isAdmin()) && isImageUpload(10);
    }

    // AI Design Studio reference images uploaded by owners/tenants/brokers/admins.
    // Path used by DesignStudioPage.tsx: design_requests/{userId}/{timestamp}_{fileName}
    match /design_requests/{userId}/{fileName} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin() || isOwnerRole());
      allow write: if isAuth() && request.auth.uid == userId && isImageUpload(10);
    }

    // Proofs: before/after photos for tickets
    match /proofs/{ticketId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && (isTechnicianRole() || isAdmin()) && isImageUpload(10);
    }

    // Owner Documents: title deeds, passports, etc.
    match /owners/{ownerId}/{allPaths=**} {
      allow read: if isAuth() && (request.auth.uid == ownerId || isAdmin());
      allow write: if isAuth() && (request.auth.uid == ownerId || isAdmin()) &&
                   request.resource.size < 15 * 1024 * 1024;
    }

    // Tenant Documents: EJARI, IDs, etc.
    match /tenants/{tenantId}/{allPaths=**} {
      allow read: if isAuth() && (request.auth.uid == tenantId || isAdmin());
      allow write: if isAuth() && (request.auth.uid == tenantId || isAdmin()) &&
                   request.resource.size < 15 * 1024 * 1024;
    }

    // Contracts: Institutional agreements
    match /contracts/{contractId}/{allPaths=**} {
      allow read: if isAuth() && (isAdmin() || isOwnerRole());
      allow write: if isAdmin();
    }

    // Invoices: Financial records
    match /invoices/{invoiceId}/{allPaths=**} {
      allow read: if isAuth() && (isAdmin() || isOwnerRole());
      allow write: if isAdmin();
    }

    match /kyc_documents/{documentId} {
      allow write: if isAuth() && request.resource.size < 15 * 1024 * 1024;
      allow read: if isAuth() && (documentId.matches(request.auth.uid + '.*') || isAdmin() || isAuditor());
    }

    match /onboarding-proof/{userId}/{intakeId}/{fileName} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin() || isAuditor());
      allow write: if isAuth() && request.auth.uid == userId &&
                   request.resource.size < 15 * 1024 * 1024 &&
                   request.resource.contentType.matches('application/pdf|image/.*');
    }

    // Default lockdown for unmanaged paths
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
