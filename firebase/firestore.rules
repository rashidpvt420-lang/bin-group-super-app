rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return getUserData().role == role;
    }

    // 1. ADMINS: Full Access
    match /{document=**} {
      allow read, write: if hasRole('admin');
    }

    // 2. USERS: Read/Write own profile
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // 3. OWNERS: See their properties and units (Live Hub)
    match /properties/{propertyId} {
      allow read: if resource.data.ownerId == request.auth.uid;
      
      match /units/{unitId} {
        allow read: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
      }
    }

    // 4. TENANTS: Auto-mapped access to Work Orders
    match /workOrders/{orderId} {
      allow create: if hasRole('tenant');
      allow read: if resource.data.tenantId == request.auth.uid || 
                     resource.data.assignedTechId == request.auth.uid || 
                     hasRole('owner');
      allow update: if hasRole('technician') && resource.data.assignedTechId == request.auth.uid;
    }
  }
}
