# Environment Configuration - Backend
# Copy to .env and fill in actual values

# ENVIRONMENT
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
API_URL=http://localhost:3000

# FIREBASE
FIREBASE_PROJECT_ID=homeos-uae
FIREBASE_PRIVATE_KEY=***REPLACE_WITH_ACTUAL_KEY***
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-@homeos-uae.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://homeos-uae.firebaseio.com

# GOOGLE MAPS
GOOGLE_MAPS_API_KEY=***REPLACE_WITH_ACTUAL_KEY***

# OPENAI
OPENAI_API_KEY=sk-proj-***REPLACE_WITH_ACTUAL_KEY***
OPENAI_MODEL=gpt-4-vision

# STRIPE
STRIPE_API_KEY=sk_live_***REPLACE_WITH_ACTUAL_KEY***
STRIPE_WEBHOOK_SECRET=whsec_***REPLACE_WITH_ACTUAL_KEY***

# WHATSAPP
WHATSAPP_BUSINESS_ACCOUNT_ID=***REPLACE_WITH_ACTUAL_ID***
WHATSAPP_API_URL=https://graph.instagram.com/v18.0
WHATSAPP_BEARER_TOKEN=***REPLACE_WITH_ACTUAL_TOKEN***
WHATSAPP_PHONE_NUMBER_ID=***REPLACE_WITH_ACTUAL_ID***

# JWT
JWT_SECRET=***GENERATE_STRONG_SECRET_MIN_32_CHARS***
JWT_EXPIRATION=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://admin.homeos.ae

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# EMAIL (Optional - for transactional emails)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=***REPLACE_WITH_SENDGRID_KEY***

# AWS BACKUP (Optional - if using AWS)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=***REPLACE_WITH_ACTUAL_KEY***
AWS_SECRET_ACCESS_KEY=***REPLACE_WITH_ACTUAL_KEY***
AWS_S3_BUCKET=homeos-backups

# MONITORING
DATADOG_API_KEY=***REPLACE_WITH_ACTUAL_KEY***
SENTRY_DSN=***REPLACE_WITH_ACTUAL_DSN***

# FEATURES (Enable/Disable)
FEATURE_IMAGE_ANALYSIS=true
FEATURE_REAL_TIME_TRACKING=true
FEATURE_PAYMENT_PROCESSING=true
FEATURE_WHATSAPP_NOTIFICATIONS=true
