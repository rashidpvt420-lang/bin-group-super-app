{
    "compilerOptions": {
        "baseUrl": ".",
        "target": "esnext",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "module": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "paths": {
            "@bin/shared": ["../../packages/shared/src"]
        },
        "types": ["node"],
        "typeRoots": ["../../node_modules/@types", "./src/types"]
    },
    "include": [
        "src",
        "../../packages/shared/src"
    ],
    "exclude": [
        "src/**/*.test.tsx",
        "src/**/*.test.ts",
        "src/__tests__",
        "src/setupTests.ts"
    ]
}
