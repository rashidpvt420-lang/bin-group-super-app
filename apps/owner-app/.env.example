# BIN GROUP Owner App - Environment Template
# Copy to .env and fill in your values. Never commit real secrets.

# Firebase config (public client-side values — not secrets)
VITE_FIREBASE_API_KEY=REPLACE_WITH_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=bin-group-57c60.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=bin-group-57c60
VITE_FIREBASE_STORAGE_BUCKET=bin-group-57c60.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_WITH_APP_ID

# Web Push / FCM — Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=REPLACE_WITH_VAPID_KEY

# Google Maps — console.cloud.google.com → APIs & Services → Credentials
# Restrict key to: Maps JavaScript API. Add HTTP referrer: bin-group-57c60.web.app/*
VITE_GOOGLE_MAPS_API_KEY=REPLACE_WITH_MAPS_KEY
VITE_ENABLE_EMBEDDED_GOOGLE_MAPS=false

# Firebase App Check reCAPTCHA v3 — Firebase Console → App Check → Register
VITE_APP_CHECK_SITE_KEY=REPLACE_WITH_RECAPTCHA_V3_SITE_KEY
VITE_ENABLE_FIREBASE_APPCHECK=false
