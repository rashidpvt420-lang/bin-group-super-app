# BIN GROUP SUPER APP - Institutional Environment Template
# [PRODUCTION NODE: bin-group-57c60]
# Copy this file to .env.local for local development. Never commit real secrets.

# ─── Firebase Core ──────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=REPLACE_WITH_PRODUCTION_KEY
VITE_FIREBASE_AUTH_DOMAIN=bin-group-57c60.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=bin-group-57c60
VITE_FIREBASE_STORAGE_BUCKET=bin-group-57c60.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_WITH_APP_ID

# ─── Firebase App Check (reCAPTCHA v3) ──────────────────────────────────────
# Required for public launch. Get site key from: console.firebase.google.com
# → App Check → Apps → Register → reCAPTCHA v3.
# Set VITE_ENABLE_FIREBASE_APPCHECK=true in production GitHub Secrets only.
VITE_APP_CHECK_SITE_KEY=REPLACE_WITH_RECAPTCHA_V3_SITE_KEY
VITE_ENABLE_FIREBASE_APPCHECK=false

# ─── Firebase Cloud Messaging (Web Push / FCM) ───────────────────────────────
# Required for mobile push notifications. Get from:
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# → Generate key pair → copy the "Key pair" value.
VITE_FIREBASE_VAPID_KEY=REPLACE_WITH_WEB_PUSH_CERTIFICATE_KEY_PAIR

# ─── Google Maps Platform ────────────────────────────────────────────────────
# Required for embedded maps and GPS dispatch. Get from:
# console.cloud.google.com → APIs & Services → Credentials → Create API Key.
# Restrict the key to: Maps JavaScript API, Static Maps API.
# Add HTTP referrer restriction: bin-group-57c60.web.app/* and your custom domain.
VITE_GOOGLE_MAPS_API_KEY=REPLACE_WITH_MAPS_KEY

# ─── Backend Secrets (Set via Firebase Secrets Manager only) ─────────────────
# DO NOT ADD TO THIS FILE. Use: firebase functions:secrets:set KEY=VALUE
# Required backend secrets: OPENAI_API_KEY, STRIPE_SECRET_KEY, SMTP_PASSWORD, GEMINI_API_KEY

