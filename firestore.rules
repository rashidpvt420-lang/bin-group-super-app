rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function authEmailMatches(value) {
      return signedIn() && authEmail() != null && value != null && value == authEmail();
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.isAdmin == true ||
        request.auth.token.ceo == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().role in ['admin', 'ceo', 'super_admin'])
      );
    }

    function hasPermission(permission) {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().permissions[permission] == true;
    }

    function isOwner(ownerId) {
      return signedIn() && ownerId != null && request.auth.uid == ownerId;
    }

    function isTenant(tenantId) {
      return signedIn() && tenantId != null && request.auth.uid == tenantId;
    }

    function isTechnician(technicianId) {
      return signedIn() && technicianId != null && request.auth.uid == technicianId;
    }

    function owns(data) {
      return isOwner(data.ownerId) || isOwner(data.ownerUid) || isOwner(data.authUid) || isOwner(data.userId) || isOwner(data.createdBy) || isOwner(data.createdByUid);
    }

    function getOwnerId(data) {
      return data.ownerId != null ? data.ownerId : (data.ownerUid != null ? data.ownerUid : null);
    }

    function isOwnerSuspended(ownerId) {
      return ownerId != null &&
        exists(/databases/$(database)/documents/users/$(ownerId)) &&
        get(/databases/$(database)/documents/users/$(ownerId)).data.status in ['suspended', 'SUSPENDED'];
    }

    function emailOwns(data) {
      return authEmailMatches(data.email) ||
        authEmailMatches(data.ownerEmail) ||
        authEmailMatches(data.tenantEmail) ||
        authEmailMatches(data.recipientEmail) ||
        authEmailMatches(data.contactEmail) ||
        authEmailMatches(data.emailDelivery.recipient) ||
        authEmailMatches(data.companyProfile.email) ||
        authEmailMatches(data.owner.email) ||
        authEmailMatches(data.ownerProfile.email);
    }

    function ownerCanRead(data) {
      return signedIn() && (owns(data) || emailOwns(data));
    }

    function tenantOwns(data) {
      return isTenant(data.tenantId) || isTenant(data.tenantUid) || isTenant(data.authUid) || isTenant(data.userId) || isTenant(data.createdByUid);
    }

    function techOwns(data) {
      return isTechnician(data.assignedTechnicianId) || isTechnician(data.technicianId);
    }

    function isPropMember(propertyId) {
      return signedIn() && propertyId != null && exists(/databases/$(database)/documents/propertyMembers/$(propertyId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/propertyMembers/$(propertyId)/members/$(request.auth.uid)).data.active == true;
    }

    function getPropMember(propertyId) {
      return get(/databases/$(database)/documents/propertyMembers/$(propertyId)/members/$(request.auth.uid)).data;
    }

    function safeOwnerOnboardingProfileUpdate(userId) {
      return signedIn() && userId == request.auth.uid &&
        request.resource.data.role == 'owner' &&
        request.resource.data.status in ['pending_admin_approval', 'pending_approval', 'active'] &&
        request.resource.data.adminApproved == false &&
        request.resource.data.paymentVerified == false &&
        request.resource.data.dashboardLocked == true &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false) &&
        (!('admin' in request.resource.data) || request.resource.data.admin == false) &&
        (!('permissions' in request.resource.data) || request.resource.data.permissions == resource.data.permissions) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid','email','displayName','name','phone','mobile','photoURL','language',
          'role','status','dashboardLocked','onboardingSubmissionId','latestIntakeId','createdAt','updatedAt','lastLoginAt','legalAcceptedAt',
          'pdplCompliance','gpsConsent','onboardingComplete'
        ]);
    }

    function designParticipant(data) {
      return signedIn() && (owns(data) || tenantOwns(data) || emailOwns(data));
    }

    function designCreateOwnerOrTenant(data) {
      return signedIn() && (
        data.userId == request.auth.uid ||
        data.createdByUid == request.auth.uid ||
        data.ownerId == request.auth.uid ||
        data.ownerUid == request.auth.uid ||
        data.tenantId == request.auth.uid ||
        data.tenantUid == request.auth.uid
      );
    }

    function safeDesignOwnerDecisionUpdate() {
      return signedIn() && owns(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status','approvalStatus','quoteStatus','workflowStage','payerRole','payerId','ownerId','ownerUid','ownerAction','ownerActionAt','updatedAt'
        ]) &&
        request.resource.data.status in ['OWNER_APPROVED_TENANT_TO_PAY','OWNER_APPROVED_OWNER_TO_PAY','OWNER_REJECTED','DEPOSIT_PENDING','REJECTED'] &&
        (!('paymentStatus' in request.resource.data) || request.resource.data.paymentStatus == resource.data.paymentStatus);
    }

    function safeDesignPaymentRequestUpdate() {
      return signedIn() && designParticipant(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status','workflowStage','paymentId','paymentStatus','executionStatus','adminHandoffStatus','engineerHandoffStatus','executionScope','updatedAt','paymentRequestedAt'
        ]) &&
        request.resource.data.status == 'PAYMENT_PENDING' &&
        request.resource.data.paymentStatus == 'PENDING_ADMIN_PAYMENT_VERIFICATION';
    }

    function safeApprovalDecisionUpdate() {
      return signedIn() && owns(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'decision','status','approvalStatus','payerRole','payerId','ownerAction','approvedAt','rejectedAt','updatedAt','decidedBy','decidedByEmail'
        ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || emailOwns(resource.data) || isAdmin() || hasPermission('canViewAuditLogs') || hasPermission('canManageStaff');
      allow create: if signedIn() && isOwner(userId) && request.resource.data.role in ['tenant', 'owner', 'broker', 'technician'];
      allow update: if isAdmin() || hasPermission('canManageStaff') || safeOwnerOnboardingProfileUpdate(userId) || (
        isOwner(userId) &&
        ((resource.data.role == null && request.resource.data.role in ['tenant', 'owner', 'broker', 'technician']) || request.resource.data.role == resource.data.role) &&
        (!('permissions' in request.resource.data) || request.resource.data.permissions == resource.data.permissions) &&
        (!('admin' in request.resource.data) || request.resource.data.admin == resource.data.admin) &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == resource.data.isAdmin) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid','email','displayName','name','phone','mobile','photoURL','language',
          'role','status','dashboardLocked','onboardingSubmissionId','latestIntakeId',
          'createdAt','updatedAt','lastLoginAt','legalAcceptedAt','pdplCompliance','gpsConsent','onboardingComplete',
          'fcmTokens','pushEnabled','pushUpdatedAt','dutyStatus','onDuty','shiftStartedAt','shiftEndedAt',
          'breakStartedAt','breakEndedAt','dutyStartedAt','dutyEndedAt','lastLocation','lastSeenAt'
        ])
      );
      allow delete: if isAdmin() || hasPermission('canManageStaff');

      match /fcmTokens/{tokenId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin() || hasPermission('canManageStaff');
      }
    }

    match /propertyMembers/{propertyId} {
      allow read: if isAdmin() || hasPermission('canManageProperties');
      match /members/{memberId} {
        allow read: if isAdmin() || hasPermission('canManageProperties') || (signedIn() && memberId == request.auth.uid);
        allow write: if isAdmin() || hasPermission('canManageProperties');
      }
    }

    match /intake_submissions/{intakeId} {
      allow read: if isAdmin() || ownerCanRead(resource.data);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid && request.resource.data.ownerEmail == request.auth.token.email;
      allow update: if isAdmin() || (signedIn() && (resource.data.ownerUid == request.auth.uid || resource.data.ownerEmail == request.auth.token.email) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerUid', 'ownerEmail', 'accountCreated', 'accountCreatedAt', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /staffAccess/{accessId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs');
      allow write: if isAdmin() || hasPermission('canManageStaff');
    }

    match /owners/{ownerId} {
      allow read: if isOwner(ownerId) || emailOwns(resource.data) || isAdmin() || hasPermission('canManageTenants');
      allow create, update: if isOwner(ownerId) || isAdmin() || hasPermission('canManageTenants');
      allow delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /properties/{propertyId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data) ||
        (signedIn() && (resource.data.assignedTechnicianId == request.auth.uid || resource.data.technicianId == request.auth.uid ||
          (isPropMember(propertyId) && getPropMember(propertyId).role in ['owner', 'tenant', 'technician'])));
      allow create, update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /units/{unitId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data) ||
        (signedIn() && (resource.data.tenantId == request.auth.uid || resource.data.tenantUid == request.auth.uid ||
          (isPropMember(resource.data.propertyId) && (getPropMember(resource.data.propertyId).role == 'owner' ||
            (getPropMember(resource.data.propertyId).role == 'tenant' && getPropMember(resource.data.propertyId).unitId == unitId)))));
      allow create, update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /tenants/{tenantId} {
      allow read: if isAdmin() || owns(resource.data) || emailOwns(resource.data) || tenantOwns(resource.data) || isOwner(tenantId) || hasPermission('canManageTenants');
      allow create, update, delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /technicians/{techId} {
      // Admin/dispatcher: full access
      // Technician: read own profile; update only live-tracking/duty fields (never role/permissions)
      allow read: if isAdmin() || hasPermission('canManageTechnicians') || hasPermission('canDispatchJobs') || isTechnician(techId);
      allow create, delete: if isAdmin() || hasPermission('canManageTechnicians');
      allow update: if isAdmin() || hasPermission('canManageTechnicians') || (
        isTechnician(techId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'currentLocation','lastLocation','locationUpdatedAt',
          'activeTicketId','isTracking','isOnDuty','onDuty',
          'dutyStatus','shiftStartedAt','shiftEndedAt','lastSeenAt','updatedAt'
        ])
      );
    }

    match /settings/companyProfile {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('canManageCompanyProfile');
    }

    match /maintenanceTickets/{ticketId} {
      // CREATE: admin, dispatcher, tenant filing their own request, OR owner filing against their own property
      allow create: if isAdmin() || hasPermission('canDispatchJobs') ||
        (signedIn() && !isOwnerSuspended(getOwnerId(request.resource.data)) && (
          tenantOwns(request.resource.data) ||
          owns(request.resource.data)
        ));

      // READ: admin, dispatcher, owner of the property, tenant linked to ticket, assigned technician
      allow read: if isAdmin() || owns(resource.data) || emailOwns(resource.data) || tenantOwns(resource.data) || techOwns(resource.data) || hasPermission('canDispatchJobs') ||
        (signedIn() && isPropMember(resource.data.propertyId) && (getPropMember(resource.data.propertyId).role == 'owner' ||
          (getPropMember(resource.data.propertyId).role == 'tenant' && getPropMember(resource.data.propertyId).unitId == resource.data.unitId)));

      // UPDATE rules — each rule is limited to its own safe field set
      allow update: if isAdmin() || hasPermission('canDispatchJobs') ||
        (!isOwnerSuspended(getOwnerId(resource.data)) && (
          // Tenant can approve/reject/rate their own completed ticket
          (tenantOwns(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status','rating','feedback','tenantApproved','rejectionReason','closedAt','updatedAt'
          ])) ||

          // Owner can approve cost/status on their own ticket
          (owns(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status','approvedAt','estimatedCostApproved','updatedAt'
          ])) ||

          // Assigned technician: job notes, photos, completion fields, AND live GPS location
          (techOwns(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status','techNotes','technicianNotes','materialsUsed','actualCost',
            'completedAt','beforePhotoUrl','afterPhotoUrl','signatureUrl','notes',
            'tenantApprovalRequired','updatedAt','startedAt','arrivedAt','onTheWayAt',
            'waitingPartsAt','escalatedAt','completedPendingApprovalAt',
            'beforePhotos','afterPhotos','evidencePhotos','proofPhotos','completionPhotos',
            'technicianLocation','technicianLocationUpdatedAt','trackingStatus','dispatchStatus'
          ])) ||

          // Any authenticated technician can self-assign an unassigned open ticket
          // and write their identity snapshot into the ticket on accept
          (signedIn() && userDoc().role == 'technician' &&
            (!('assignedTechnicianId' in resource.data) || resource.data.assignedTechnicianId == null || resource.data.assignedTechnicianId == '') &&
            resource.data.status in ['OPEN','open','PENDING_ASSIGNMENT','pending_assignment'] &&
            request.resource.data.assignedTechnicianId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status','assignedTechnicianId','technicianId','acceptedAt','updatedAt',
              'assignedTechnicianName','assignedTechnicianPhone','assignedTechnicianAvatar',
              'technicianSpecialty','dispatchStatus','trackingStatus'
            ]))
        ));

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || tenantOwns(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data) || techOwns(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data) || hasPermission('canDispatchJobs');
        allow create: if (isAdmin() || tenantOwns(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data) || techOwns(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data) || hasPermission('canDispatchJobs')) && request.resource.data.senderUid == request.auth.uid && request.resource.data.keys().hasAll(['senderUid', 'senderRole', 'message', 'createdAt']);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /notifications/{notifId} {
      allow read: if isAdmin() || (signedIn() && resource.data.recipientId == request.auth.uid);
      allow create: if isAdmin() || (signedIn() && request.resource.data.recipientId == request.auth.uid);
      allow update: if isAdmin() || (signedIn() && resource.data.recipientId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
      allow delete: if isAdmin();
    }

    match /brokerReferrals/{referralId} {
      allow read: if isAdmin() || (signedIn() && resource.data.brokerId == request.auth.uid);
      allow create: if isAdmin() || (signedIn() && request.resource.data.brokerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /auditLogs/{auditId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || (signedIn() && resource.data.actorId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /audit_logs/{auditId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || (signedIn() && resource.data.actorId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /disputes/{disputeId} {
      allow read: if isAdmin() || hasPermission('canManageTenants') || (signedIn() && resource.data.tenantId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /ownerInvites/{token} {
      allow read: if isAdmin() || emailOwns(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /ownerBankAccounts/{accountId} {
      allow read: if isAdmin() || ownerCanRead(resource.data);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /propertyPassports/{passportId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data) || (signedIn() && isPropMember(passportId) && getPropMember(passportId).role in ['owner', 'tenant', 'technician']);
      allow create, update: if isAdmin() || hasPermission('canManageProperties');
      allow delete: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read: if isAdmin() || hasPermission('canManageContracts') || ownerCanRead(resource.data);
      allow create: if isAdmin() || hasPermission('canManageContracts');
      allow update: if isAdmin() || hasPermission('canManageContracts') || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.ownerUid == request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'signedAt', 'updatedAt']) &&
        (!('paymentVerified' in request.resource.data) || request.resource.data.paymentVerified == resource.data.paymentVerified) &&
        (!('status' in request.resource.data) || request.resource.data.status != 'ACTIVE'));
      allow delete: if isAdmin();
    }

    match /leases/{leaseId} {
      allow read: if isAdmin() || hasPermission('canManageTenants') || ownerCanRead(resource.data) || (signedIn() && (resource.data.tenantId == request.auth.uid || resource.data.tenantUid == request.auth.uid));
      allow write: if isAdmin() || hasPermission('canManageTenants');
    }

    match /tenant_ledger/{ledgerId} {
      allow read: if isAdmin() || ownerCanRead(resource.data) || (signedIn() && (resource.data.tenantId == request.auth.uid || resource.data.tenantUid == request.auth.uid));
      allow write: if isAdmin();
    }

    match /occupancies/{occupancyId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.ownerUid == request.auth.uid || resource.data.tenantUid == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow write: if isAdmin() || (signedIn() && (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerUid == request.auth.uid));
    }

    match /tenantInvitations/{inviteId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.ownerUid == request.auth.uid || resource.data.tenantUid == request.auth.uid || resource.data.tenantEmail == request.auth.token.email));
      allow write: if isAdmin() || (signedIn() && (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerUid == request.auth.uid));
    }

    match /propertyReporters/{reporterId} {
      allow read: if isAdmin() || ownerCanRead(resource.data) ||
        (signedIn() && (
          resource.data.reporterUid == request.auth.uid ||
          resource.data.reporterEmail == request.auth.token.email
        ));

      allow create: if isAdmin() || (
        signedIn() &&
        (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerUid == request.auth.uid) &&
        request.resource.data.propertyId is string &&
        request.resource.data.reporterName is string &&
        request.resource.data.reporterEmail is string &&
        request.resource.data.reporterPhone is string &&
        request.resource.data.accessStatus in ['INVITED','ACTIVE'] &&
        request.resource.data.permissionScope in ['COMPLAINTS_ONLY','VIEW_AND_COMPLAIN','OWNER_DELEGATE'] &&
        request.resource.data.canViewOwnerFinancials == false
      );

      allow update: if isAdmin() || (
        signedIn() &&
        (resource.data.ownerId == request.auth.uid || resource.data.ownerUid == request.auth.uid) &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'accessStatus','canCreateComplaints','canViewOwnComplaints','canViewPropertyComplaints',
          'canActOnOwnerBehalf','canViewOwnerFinancials','canApproveWork','updatedAt'
        ]) &&
        request.resource.data.canViewOwnerFinancials == false
      );

      allow delete: if isAdmin();
    }

    match /hrProfiles/{profileId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || isOwner(profileId);
      allow write: if isAdmin() || hasPermission('canManageStaff');
    }

    match /attendanceLogs/{logId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /hrRequests/{requestId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || hasPermission('canManageStaff');
      allow delete: if isAdmin();
    }

    match /payment_transactions/{paymentId} {
      allow read: if isAdmin() || hasPermission('canManageContracts') || ownerCanRead(resource.data) || (signedIn() && (resource.data.tenantId == request.auth.uid || resource.data.tenantUid == request.auth.uid || resource.data.payerId == request.auth.uid || resource.data.userId == request.auth.uid));
      allow create: if signedIn() &&
        (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerUid == request.auth.uid || request.resource.data.tenantId == request.auth.uid || request.resource.data.tenantUid == request.auth.uid || request.resource.data.payerId == request.auth.uid || request.resource.data.userId == request.auth.uid) &&
        (!('paymentVerified' in request.resource.data) || request.resource.data.paymentVerified == false) &&
        (!('approved' in request.resource.data) || request.resource.data.approved == false) &&
        (!('unlocksDashboard' in request.resource.data) || request.resource.data.unlocksDashboard == false) &&
        (!('status' in request.resource.data) || request.resource.data.status != 'ACTIVE') &&
        (!('contractActivated' in request.resource.data) || request.resource.data.contractActivated == false);
      allow update: if isAdmin() || hasPermission('canManageContracts');
      allow delete: if isAdmin();
    }

    match /design_requests/{requestId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || designParticipant(resource.data);
      allow create: if designCreateOwnerOrTenant(request.resource.data) &&
        request.resource.data.status in ['PENDING_OWNER_NOC','AI_CONCEPT_READY','AWAITING_OWNER_APPROVAL','DEPOSIT_PENDING'] &&
        (!('paymentStatus' in request.resource.data) || request.resource.data.paymentStatus in ['NOT_STARTED','PENDING']) &&
        (!('approvalStatus' in request.resource.data) || request.resource.data.approvalStatus in ['PENDING_OWNER_APPROVAL','NOT_REQUIRED']);
      allow update: if isAdmin() || hasPermission('canManageProperties') || safeDesignOwnerDecisionUpdate() || safeDesignPaymentRequestUpdate();
      allow delete: if isAdmin();
    }

    match /design_quotes/{quoteId} {
      allow read: if isAdmin() || designParticipant(resource.data);
      allow create: if designCreateOwnerOrTenant(request.resource.data) &&
        (!('paymentStatus' in request.resource.data) || request.resource.data.paymentStatus in ['NOT_STARTED','PENDING']) &&
        (!('quoteStatus' in request.resource.data) || request.resource.data.quoteStatus in ['AWAITING_OWNER_APPROVAL','DEPOSIT_PENDING','AI_CONCEPT_READY']);
      allow update: if isAdmin() || hasPermission('canManageProperties');
      allow delete: if isAdmin();
    }

    match /design_concepts/{conceptId} {
      allow read: if isAdmin() || designParticipant(resource.data);
      allow create: if designCreateOwnerOrTenant(request.resource.data);
      allow update: if isAdmin() || hasPermission('canManageProperties');
      allow delete: if isAdmin();
    }

    match /design_approvals/{approvalId} {
      allow read: if isAdmin() || designParticipant(resource.data);
      allow create: if designCreateOwnerOrTenant(request.resource.data) &&
        request.resource.data.status in ['PENDING_OWNER_APPROVAL','NOT_REQUIRED','PENDING_OWNER_NOC'];
      allow update: if isAdmin() || hasPermission('canManageProperties') || safeApprovalDecisionUpdate();
      allow delete: if isAdmin();
    }

    match /design_payments/{paymentId} {
      allow read: if isAdmin() || designParticipant(resource.data);
      allow create: if designCreateOwnerOrTenant(request.resource.data) &&
        request.resource.data.status in ['PENDING_ADMIN_PAYMENT_VERIFICATION','PENDING_PAYMENT','NOT_STARTED'];
      allow update, delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /binGptEngineerCommands/{commandId} {
      allow read, create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /gatePasses/{passId} {
      allow read, write: if isAdmin() || (signedIn() && (resource.data.tenantUid == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.tenantUid == request.auth.uid || request.resource.data.tenantId == request.auth.uid);
    }

    match /amenityBookings/{bookingId} {
      allow read, write: if isAdmin() || (signedIn() && (resource.data.tenantUid == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.tenantUid == request.auth.uid || request.resource.data.tenantId == request.auth.uid);
    }

    match /broker_commissions/{commissionId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.brokerId == request.auth.uid || resource.data.brokerUid == request.auth.uid));
      allow write: if isAdmin();
    }

    match /commissions/{commissionId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.brokerId == request.auth.uid || resource.data.brokerUid == request.auth.uid));
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
