rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Institutional Helper Functions ─────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && userDoc().role in ['admin', 'ceo'];
    }

    function hasPermission(permission) {
      return signedIn() && userDoc().permissions[permission] == true;
    }

    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    function isTenant(tenantId) {
      return signedIn() && request.auth.uid == tenantId;
    }

    function isTechnician(technicianId) {
      return signedIn() && request.auth.uid == technicianId;
    }

    function owns(data) {
      return isOwner(data.ownerId) || isOwner(data.userId) || isOwner(data.createdBy);
    }

    function tenantOwns(data) {
      return isTenant(data.tenantId) || isTenant(data.authUid) || isTenant(data.userId);
    }

    function techOwns(data) {
      return isTechnician(data.assignedTechnicianId) || isTechnician(data.technicianId);
    }

    function isOwnerRole() {
      return signedIn() && userDoc().role == 'owner';
    }

    function isTechnicianRole() {
      return signedIn() && userDoc().role == 'technician';
    }

    function validContractType(contractType) {
      return contractType in ['FM_ONLY', 'PM_ONLY', 'FM_PM', 'fm_only', 'pm_only', 'fm_pm', 'hybrid', 'maintenance', 'property_management'];
    }

    function isSafeOwnerSignupProfile(userId) {
      return signedIn() && request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email.lower() &&
        request.resource.data.role == 'owner';
    }

    // ─── Core Collections ─────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || hasPermission('canViewAuditLogs') || hasPermission('canManageStaff');
      allow create: if (
        signedIn() && isOwner(userId) && request.resource.data.role in ['tenant', 'owner', 'broker', 'technician']
      );
      allow update: if isAdmin() || hasPermission('canManageStaff') || (
        isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.permissions == resource.data.permissions &&
        (
          (resource.data.role == 'technician' && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'dutyStatus', 'onDuty', 'shiftStartedAt', 'shiftEndedAt', 'breakStartedAt', 'breakEndedAt', 'updatedAt'
          ])) ||
          (resource.data.role != 'technician' && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName','name','phone','mobile','photoURL','language',
            'updatedAt','lastLoginAt','legalAcceptedAt','pdplCompliance',
            'gpsConsent','onboardingComplete','fcmTokens',
            'dutyStatus', 'onDuty', 'shiftStartedAt', 'shiftEndedAt', 'breakStartedAt', 'breakEndedAt',
            'status', 'dashboardLocked', 'adminApproved', 'paymentVerified', 'onboardingSubmissionId'
          ]))
        )
      );
      allow delete: if isAdmin() || hasPermission('canManageStaff');
    }

    match /intake_submissions/{intakeId} {
      allow read: if isAdmin() || (
        signedIn() && (
          resource.data.ownerUid == request.auth.uid ||
          resource.data.ownerId == request.auth.uid ||
          resource.data.userId == request.auth.uid ||
          resource.data.ownerEmail == request.auth.token.email
        )
      );
      allow create: if signedIn() &&
        (
          request.resource.data.ownerUid == request.auth.uid ||
          request.resource.data.ownerId == request.auth.uid ||
          request.resource.data.userId == request.auth.uid
        ) &&
        request.resource.data.ownerEmail == request.auth.token.email;
      allow update: if isAdmin() || (
        signedIn() &&
        (resource.data.ownerUid == request.auth.uid || resource.data.ownerId == request.auth.uid || resource.data.ownerEmail == request.auth.token.email) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'ownerUid', 'ownerId', 'ownerEmail', 'accountCreated', 'accountCreatedAt', 'updatedAt'
        ])
      );
      allow delete: if isAdmin();
    }

    match /ownerOnboarding/{onboardingId} {
      allow read: if isAdmin() || hasPermission('canManageContracts') || (
        signedIn() && (
          resource.data.ownerId == request.auth.uid ||
          resource.data.ownerUid == request.auth.uid ||
          resource.data.ownerEmail == request.auth.token.email
        )
      );
      allow create: if signedIn() && isOwnerRole() &&
        (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerUid == request.auth.uid) &&
        request.resource.data.status in ['DRAFT', 'PENDING', 'PAYMENT_PENDING', 'AWAITING_VERIFICATION'];
      allow update: if isAdmin() || hasPermission('canManageContracts') || (
        signedIn() &&
        (resource.data.ownerId == request.auth.uid || resource.data.ownerUid == request.auth.uid) &&
        resource.data.status in ['DRAFT', 'PENDING', 'PAYMENT_PENDING'] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'step', 'bankAccountRef', 'propertyId', 'contractType', 'selectedAddOns',
          'paymentMethod', 'status', 'updatedAt'
        ])
      );
      allow delete: if isAdmin();
    }

    match /staffAccess/{accessId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs');
      allow write: if isAdmin() || hasPermission('canManageStaff');
    }

    match /owners/{ownerId} {
      allow read: if isOwner(ownerId) || isAdmin() || hasPermission('canManageTenants');
      allow create, update, delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /properties/{propertyId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /properties_pending/{propertyId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || owns(resource.data);
      allow create: if isAdmin() || hasPermission('canManageProperties') || (
        signedIn() && isOwnerRole() && request.resource.data.ownerId == request.auth.uid
      );
      allow update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /units/{unitId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /tenants/{tenantId} {
      allow read: if isAdmin() || owns(resource.data) || tenantOwns(resource.data) || isOwner(tenantId) || hasPermission('canManageTenants');
      allow create, update, delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /technicians/{techId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || hasPermission('canManageTechnicians');
    }

    match /technicianLocations/{techId} {
      allow read: if isAdmin() || hasPermission('canDispatchJobs') || isTechnician(techId);
      allow create: if isTechnician(techId) &&
        request.resource.data.technicianId == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'technicianId', 'lat', 'lng', 'geohash', 'geo', 'heading', 'speed',
          'accuracy', 'dutyStatus', 'onDuty', 'activeTicketId', 'lastSeenAt', 'updatedAt'
        ]);
      allow update: if isTechnician(techId) &&
        request.resource.data.technicianId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'technicianId', 'lat', 'lng', 'geohash', 'geo', 'heading', 'speed',
          'accuracy', 'dutyStatus', 'onDuty', 'activeTicketId', 'lastSeenAt', 'updatedAt'
        ]);
      allow delete: if isAdmin() || hasPermission('canManageTechnicians');
    }

    match /settings/companyProfile {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('canManageCompanyProfile');
    }

    match /maintenanceTickets/{ticketId} {
      allow create: if isAdmin() || hasPermission('canDispatchJobs') || (signedIn() && tenantOwns(request.resource.data));
      allow read: if isAdmin() || owns(resource.data) || tenantOwns(resource.data) || techOwns(resource.data) || hasPermission('canDispatchJobs');
      allow update: if isAdmin() || hasPermission('canDispatchJobs') ||
        (tenantOwns(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'rating', 'feedback', 'tenantApproved',
            'rejectionReason', 'closedAt', 'updatedAt'
          ])) ||
        (owns(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'approvedAt', 'estimatedCostApproved', 'updatedAt'
          ])) ||
        (techOwns(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'techNotes', 'technicianNotes', 'materialsUsed',
            'actualCost', 'completedAt', 'beforePhotoUrl', 'afterPhotoUrl',
            'signatureUrl', 'notes', 'tenantApprovalRequired', 'updatedAt'
          ])) ||
        (isTechnicianRole() &&
          (!('assignedTechnicianId' in resource.data) || resource.data.assignedTechnicianId == null || resource.data.assignedTechnicianId == "") &&
          resource.data.status in ['OPEN', 'open', 'PENDING_ASSIGNMENT', 'pending_assignment'] &&
          request.resource.data.assignedTechnicianId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'assignedTechnicianId', 'technicianId', 'acceptedAt', 'updatedAt'
          ]));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() ||
          tenantOwns(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data) ||
          techOwns(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data) ||
          hasPermission('canDispatchJobs');

        allow create: if (
          isAdmin() ||
          tenantOwns(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data) ||
          techOwns(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data) ||
          hasPermission('canDispatchJobs')
        ) && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.keys().hasAll(['senderUid', 'senderRole', 'message', 'createdAt']);

        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /notifications/{notifId} {
      allow read: if isAdmin() || (signedIn() && resource.data.recipientId == request.auth.uid);
      allow create: if isAdmin() || (signedIn() && request.resource.data.recipientId == request.auth.uid);
      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.recipientId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])
      );
      allow delete: if isAdmin();
    }

    match /brokerReferrals/{referralId} {
      allow read: if isAdmin() || (signedIn() && resource.data.brokerId == request.auth.uid);
      allow create: if isAdmin() || (signedIn() && request.resource.data.brokerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /auditLogs/{auditId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || (signedIn() && resource.data.actorId == request.auth.uid);
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /audit_logs/{auditId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || (signedIn() && resource.data.actorId == request.auth.uid);
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /disputes/{disputeId} {
      allow read: if isAdmin() || hasPermission('canManageTenants') || (signedIn() && resource.data.tenantId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /ownerInvites/{token} {
      allow read: if isAdmin() || (signedIn() && resource.data.ownerEmail == request.auth.token.email);
      allow create, update, delete: if isAdmin();
    }

    match /ownerBankAccounts/{accountId} {
      allow read: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if signedIn() && isOwnerRole() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /propertyPassports/{passportId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || (
        signedIn() && (
          resource.data.ownerId == request.auth.uid ||
          resource.data.ownerEmail == request.auth.token.email
        )
      );
      allow create, update: if isAdmin() || hasPermission('canManageProperties');
      allow delete: if isAdmin();
    }

    match /contractTemplates/{templateId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /contracts/{contractId} {
      allow read: if isAdmin() || hasPermission('canManageContracts') || (
        signedIn() && (
          resource.data.ownerId == request.auth.uid ||
          resource.data.ownerEmail == request.auth.token.email ||
          resource.data.createdBy == request.auth.uid
        )
      );
      allow create: if isAdmin() || hasPermission('canManageContracts') || (
        signedIn() && isOwnerRole() &&
        (validContractType(request.resource.data.contractType) || validContractType(request.resource.data.planType)) &&
        (
          request.resource.data.ownerId == request.auth.uid ||
          request.resource.data.ownerEmail == request.auth.token.email ||
          request.resource.data.createdBy == request.auth.uid
        ) &&
        request.resource.data.status in ['DRAFT', 'PENDING_APPROVAL', 'PAYMENT_PENDING']
      );
      allow update: if isAdmin() || hasPermission('canManageContracts') || (
        signedIn() && resource.data.ownerId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'signedAt', 'signatureState', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || hasPermission('canManagePayments') || (
        signedIn() && (
          resource.data.ownerId == request.auth.uid ||
          resource.data.payerId == request.auth.uid ||
          resource.data.recipientId == request.auth.uid
        )
      );
      allow create: if signedIn() && isOwnerRole() &&
        (request.resource.data.ownerId == request.auth.uid || request.resource.data.payerId == request.auth.uid) &&
        request.resource.data.status in ['PENDING', 'INITIATED'] &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0 &&
        request.resource.data.currency == 'AED';
      allow update, delete: if isAdmin() || hasPermission('canManagePayments');
    }

    match /payment_transactions/{transactionId} {
      allow read: if isAdmin() || hasPermission('canManagePayments') || (
        signedIn() && (
          resource.data.ownerId == request.auth.uid ||
          resource.data.payerId == request.auth.uid ||
          resource.data.createdBy == request.auth.uid
        )
      );
      allow create: if signedIn() && isOwnerRole() &&
        (request.resource.data.ownerId == request.auth.uid || request.resource.data.payerId == request.auth.uid || request.resource.data.createdBy == request.auth.uid) &&
        request.resource.data.status in ['PENDING', 'INITIATED'] &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0 &&
        request.resource.data.currency == 'AED';
      allow update, delete: if isAdmin() || hasPermission('canManagePayments');
    }

    match /pricingTiers/{tierId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('canManagePricing');
    }

    match /pricingMatrix/{matrixId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('canManagePricing');
    }

    match /serviceAddOns/{addonId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('canManagePricing');
    }

    match /hrProfiles/{profileId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || isOwner(profileId);
      allow write: if isAdmin() || hasPermission('canManageStaff');
    }

    match /attendanceLogs/{logId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /hrRequests/{requestId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || hasPermission('canManageStaff');
      allow delete: if isAdmin();
    }

    match /design_requests/{requestId} {
      allow read: if isAdmin() || owns(resource.data) || hasPermission('canManageProperties');
      allow create: if signedIn();
      allow update: if isAdmin() || owns(resource.data) || hasPermission('canManageProperties');
      allow delete: if isAdmin();
    }

    // Final fallback: admins only. Any new production collection must be explicitly modeled above.
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
