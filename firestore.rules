    }

    match /certifications/{certificationId} {
      allow read: if isAdmin() || isHr() || staffCanRead(resource.data);
      allow create: if isAdmin() || isHr();
      allow update: if isAdmin() || isHr();
      allow delete: if isAdmin() || isHr();
    }

    match /brokerLeads/{leadId} {
      allow read: if isAdmin() || brokerOwns(resource.data) || emailOwns(resource.data);
      allow create: if isAdmin() || brokerOwns(request.resource.data);
      allow update: if isAdmin() || brokerOwns(resource.data);
      allow delete: if isAdmin() || brokerOwns(resource.data);
    }

    match /referrals/{referralId} {
      allow read: if isAdmin() || brokerOwns(resource.data) || emailOwns(resource.data);
      allow create: if isAdmin() || brokerOwns(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /brokerReferrals/{referralId} {
      allow read: if isAdmin() || brokerOwns(resource.data);
      allow create: if brokerOwns(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /broker_commissions/{commissionId} {
      allow read: if isAdmin() || brokerOwns(resource.data) || emailOwns(resource.data);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /commissions/{commissionId} {
      allow read: if isAdmin() || brokerOwns(resource.data) || emailOwns(resource.data);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /leases/{leaseId} {
      allow read: if participantCanRead(resource.data) || emailOwns(resource.data) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if participantCanRead(resource.data) || emailOwns(resource.data) || (signedIn() && resource.data.payerId == request.auth.uid) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /onboarding-proof/{proofId} {
      allow read: if isAdmin() || ownsOnboardingProof(resource.data);
      allow create: if safeOnboardingProofCreate(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /gatePasses/{passId} {
      allow read: if isAdmin() || (signedIn() && resource.data.tenantUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.tenantUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (signedIn() && resource.data.tenantUid == request.auth.uid);
    }

    match /amenityBookings/{bookingId} {
      allow read: if isAdmin() || (signedIn() && resource.data.tenantUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.tenantUid == request.auth.uid;
      allow update: if isAdmin() || (signedIn() && resource.data.tenantUid == request.auth.uid && request.resource.data.status == 'cancelled' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt', 'cancellationReason']));
      allow delete: if isAdmin();
    }

    match /tenantDocuments/{documentId} {
      allow read: if isAdmin() || (signedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.tenantUid == request.auth.uid ||
        resource.data.tenantId == 'ALL' ||
        emailMatches(resource.data.tenantEmail) ||
        emailMatches(resource.data.recipientEmail)
      ));
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /pricingAuditLogs/{logId} {
      allow read: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /turnover-quotes/{quoteId} {
      allow read: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid && request.resource.data.status in ['APPROVED', 'REJECTED'] && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /ownerBankAccounts/{accountId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.ownerEmail == request.auth.token.email));
      allow create: if signedIn() && (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerEmail == request.auth.token.email);
      allow update: if isAdmin() || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.ownerEmail == request.auth.token.email));
      allow delete: if isAdmin();
    }

    match /propertyPassports/{passportId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.ownerEmail == request.auth.token.email));
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /brokerDocuments/{documentId} {
      allow read: if isAdmin() || (signedIn() && resource.data.brokerId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.brokerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (signedIn() && resource.data.brokerId == request.auth.uid);
    }

    match /move_out_requests/{requestId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.userId == request.auth.uid || resource.data.tenantUid == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.tenantUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /tenant_ledger/{ledgerId} {
      allow read: if isAdmin() || (signedIn() && resource.data.tenantId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /design_requests/{requestId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdByUid == request.auth.uid);
      allow update: if isAdmin() || (signedIn() && (
        (resource.data.ownerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'approvalStatus', 'quoteStatus', 'workflowStage', 'payerRole', 'payerEmail', 'updatedAt'])) ||
        ((resource.data.userId == request.auth.uid || resource.data.payerId == request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'workflowStage', 'payerRole', 'payerEmail', 'updatedAt']))
      ));
      allow delete: if isAdmin();
    }

    match /design_quotes/{quoteId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.createdByUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /design_concepts/{conceptId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.tenantId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /design_approvals/{approvalId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.tenantUid == request.auth.uid || resource.data.ownerId == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.tenantUid == request.auth.uid || request.resource.data.ownerId == request.auth.uid);
      allow update: if isAdmin() || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.tenantUid == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /pilotFeedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.status == 'new';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // RFQ -> vendor quote -> owner approval procurement trust workflow
    // (RfqTrustWorkflowPage, VendorCommandCenterPage, OwnerApprovalCenterPage).
    match /vendor_rfqs/{rfqId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /vendor_quotes/{quoteId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /vendors/{vendorId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /owner_approval_requests/{requestId} {
      allow read: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if isAdmin();
 review/deployed-hosting-state
      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'decision', 'decisionNote', 'ownerDecisionBy', 'decidedAt', 'updatedAt']) &&
        request.resource.data.ownerDecisionBy == request.auth.uid &&
        request.resource.data.decision in ['APPROVED', 'REJECTED', 'REQUEST_MORE_QUOTES', 'EMERGENCY_APPROVED'] &&
        request.resource.data.status in ['owner_approved', 'owner_approved_emergency', 'owner_rejected', 'more_quotes_requested']
      );

      allow update: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
 main
      allow delete: if isAdmin();
    }

    match /maintenance_ledger/{ledgerId} {
      allow read: if isAdmin();
 review/deployed-hosting-state
      allow create: if isAdmin();

      allow create: if isAdmin() || (signedIn() && request.resource.data.ownerId == request.auth.uid);
 main
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /data_governance_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /communication_intake/{intakeId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }


    function isBinConnectParticipant(data) {
      return signedIn() && (
        isAdmin() ||
        (data.participantIds is list && request.auth.uid in data.participantIds) ||
        data.createdBy == request.auth.uid ||
        data.assignedAdminId == request.auth.uid
      );
    }

    function safeBinConnectThreadCreate(data) {
      return signedIn() &&
        data.createdBy == request.auth.uid &&
        data.participantIds is list &&
        request.auth.uid in data.participantIds &&
        data.status in ['open', 'pending', 'new'] &&
        data.channel in ['company_ceo', 'admin_support', 'owner_to_tenant', 'owner_to_technician', 'majlis_staff', 'maintenance_chat', 'feature_suggestion', 'dashboard_issue'];
    }

    match /binConnectThreads/{threadId} {
      allow read: if isAdmin() || isBinConnectParticipant(resource.data);
      allow create: if safeBinConnectThreadCreate(request.resource.data);
      allow update: if isAdmin() || (isBinConnectParticipant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'updatedAt', 'status']));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if exists(/databases/$(database)/documents/binConnectThreads/$(threadId)) && (isAdmin() || isBinConnectParticipant(get(/databases/$(database)/documents/binConnectThreads/$(threadId)).data));
        allow create: if exists(/databases/$(database)/documents/binConnectThreads/$(threadId)) &&
          (isAdmin() || isBinConnectParticipant(get(/databases/$(database)/documents/binConnectThreads/$(threadId)).data)) &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /{document=**} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
