rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() { 
      return isAuth() && (
        request.auth.token.admin == true || 
        request.auth.token.isAdmin == true ||
        request.auth.token.ceo == true ||
        request.auth.token.manager == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin'])
      ); 
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Role-Lock: Users cannot change their own roles or status upon account creation
      allow create: if isOwner(userId) && (request.resource.data.role == 'tenant' || request.resource.data.role == 'owner');
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /maintenanceTickets/{ticketId} {
      allow create: if isAdmin() || (isAuth() &&
        request.resource.data.companyId is string &&
        request.resource.data.propertyId is string &&
        request.resource.data.unitId is string &&
        request.resource.data.tenancyId is string &&
        request.resource.data.tenantId == request.auth.uid &&
        request.resource.data.geo.lat is number &&
        request.resource.data.geo.lng is number &&
        request.resource.data.geo.lat >= -90 &&
        request.resource.data.geo.lat <= 90 &&
        request.resource.data.geo.lng >= -180 &&
        request.resource.data.geo.lng <= 180);
      
      allow read: if isAuth() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid || 
        resource.data.assignedTechnicianId == request.auth.uid ||
        isAdmin()
      );
      
      allow update: if isAuth() && (
        (resource.data.tenantId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'rating', 'feedback'])) ||
        (resource.data.ownerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'approvedAt', 'estimatedCostApproved'])) ||
        (resource.data.assignedTechnicianId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'techNotes', 'actualCost', 'completedAt'])) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /intake_submissions/{id} {
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status in ['DRAFT', 'IN_PROGRESS'];
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (
        isAuth() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        resource.data.status in ['DRAFT', 'IN_PROGRESS'] &&
        request.resource.data.status in ['DRAFT', 'IN_PROGRESS'] &&
        request.resource.data.dashboardUnlocked != true
      );
      allow delete: if isAdmin();
    }

    match /properties_pending/{propertyId} {
      allow read: if isAuth() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow write: if isAdmin() &&
        request.resource.data.companyId is string &&
        request.resource.data.ownerId is string &&
        request.resource.data.geo.lat is number &&
        request.resource.data.geo.lng is number &&
        request.resource.data.geo.lat >= -90 &&
        request.resource.data.geo.lat <= 90 &&
        request.resource.data.geo.lng >= -180 &&
        request.resource.data.geo.lng <= 180 &&
        (request.resource.data.geo.address is string || request.resource.data.geo.placeId is string) &&
        request.resource.data.geo.emirate is string &&
        (request.resource.data.geo.city is string || request.resource.data.geo.area is string) &&
        request.resource.data.dispatchReady == false &&
        request.resource.data.verified == false &&
        request.resource.data.approved == false;
    }

    match /properties/{propertyId} {
      allow read: if isAuth() && (resource.data.ownerId == request.auth.uid || isAdmin()); 
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if isAuth() && (resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /tenancies/{tenancyId} {
      allow read: if isAuth() && (resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read: if isAuth() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /payment_transactions/{paymentId} {
      allow read: if isAuth() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /owners/{ownerId} {
      allow read: if isOwner(ownerId) || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audit_logs/{auditId} {
      allow read: if isAdmin() || (isAuth() && resource.data.actorId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /telemetry_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /design_requests/{requestId} {
      allow create: if isAuth();
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /move_out_requests/{requestId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
