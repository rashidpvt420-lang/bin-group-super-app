rules_version = '2';

/**
 * BIN-GROUP Enterprise SaaS — Firestore Security Rules
 * 4-Layer Architecture: RBAC + Data Isolation
 *
 * Roles: ADMIN > OWNER > TECHNICIAN > TENANT
 * Principle: minimum privilege. Each role reads/writes ONLY what they need.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Live role lookup (resilient to missing documents)
    function role() {
      return get(/databases/$(database)/documents/users/$(uid())).get('role', 'pending');
    }

    function isAdmin()      { return isAuth() && (role() == 'admin' || role() == 'ADMIN'); }
    function isOwner()      { return isAuth() && (role() == 'owner' || role() == 'OWNER'); }
    function isTechnician() { return isAuth() && (role() == 'technician' || role() == 'TECHNICIAN'); }
    function isTenant()     { return isAuth() && (role() == 'tenant' || role() == 'TENANT'); }

    // Check if a user is NOT suspended
    function isActive() {
      return !exists(/databases/$(database)/documents/users/$(uid())) || 
             get(/databases/$(database)/documents/users/$(uid())).get('isSuspended', false) != true;
    }

    // ─── 1. USERS & PROFILES ────────────────────────────────────────────────
    // Baseline: Authenticated users can ALWAYS read their own profile to resolve their role.
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isAdmin());
      // Users can only create their own profile. admin/godMode MUST be false by default if client-side created.
      allow create: if isAuth() && uid() == userId && (
                      request.resource.data.get('isAdmin', false) == false &&
                      request.resource.data.get('godMode', false) == false
                    );
      // Users can update their profile but CANNOT change sensitivity fields (role, isAdmin, godMode, isSuspended).
      allow update: if isAuth() && (
                      isAdmin() || 
                      (uid() == userId && 
                        request.resource.data.get('isAdmin', resource.data.isAdmin) == resource.data.isAdmin &&
                        request.resource.data.get('godMode', resource.data.godMode) == resource.data.godMode &&
                        request.resource.data.get('role', resource.data.role) == resource.data.role &&
                        request.resource.data.get('isSuspended', resource.data.isSuspended) == resource.data.isSuspended
                      )
                    );
      allow delete: if false; // Soft delete only
    }

    // ─── 2. PROPERTIES ──────────────────────────────────────────────────────
    match /properties/{propertyId} {
      allow read:   if isAuth() && isActive() && (
                      isAdmin() ||
                      (isOwner() && resource.data.ownerId == uid())
                    );
      allow create: if isAuth() && isActive() && (
                      isAdmin() ||
                      (isOwner() && request.resource.data.ownerId == uid())
                    );
      allow update: if isAuth() && isActive() && (
                      isAdmin() ||
                      (isOwner() && resource.data.ownerId == uid())
                    );
      allow delete: if false;

      match /units/{unitId} {
        allow read: if isAuth() && isActive() && (
                      isAdmin() ||
                      (isOwner() && get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == uid()) ||
                      isTechnician() ||
                      (isTenant() && resource.data.tenantId == uid())
                    );
        allow write: if isAuth() && isActive() && (
                       isAdmin() ||
                       (isOwner() && get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == uid())
                     );

        match /assets/{assetId} {
          allow read: if isAuth() && isActive() && (
                        isAdmin() || isOwner() || isTechnician()
                      );
          allow write: if isAuth() && isActive() && (
                         isAdmin() ||
                         (isOwner() && get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == uid()) ||
                         isTechnician()
                       );
        }
      }
    }

    // ─── 3. WORK ORDERS (Tickets / Jobs) ────────────────────────────────────
    match /workOrders/{workOrderId} {
      allow read: if isAuth() && isActive() && (
                    isAdmin() ||
                    isOwner() ||
                    (isTechnician() && resource.data.technicianAssigned == uid()) ||
                    (isTenant() && resource.data.tenantId == uid())
                  );
      allow create: if isAuth() && isActive() && (
                      isAdmin() ||
                      (isOwner() && get(/databases/$(database)/documents/properties/$(request.resource.data.propertyId)).data.ownerId == uid()) ||
                      (isTenant() && get(/databases/$(database)/documents/properties/$(request.resource.data.propertyId)/units/$(request.resource.data.unitId)).data.tenantId == uid())
                    );
      allow update: if isAuth() && isActive() && (
                      isAdmin() ||
                      (isTechnician() && resource.data.technicianAssigned == uid()) ||
                      (isTenant() && resource.data.tenantId == uid()) ||
                      isOwner()
                    );
      allow delete: if false;
    }

    match /tickets/{ticketId} {
      allow read: if isAuth() && isActive() && (
                    isAdmin() ||
                    isOwner() ||
                    (isTechnician() && resource.data.technicianAssigned == uid()) ||
                    (isTenant() && (resource.data.tenantId == uid() || resource.data.userId == uid()))
                  );
      allow create: if isAuth() && isActive() && (
                      isAdmin() ||
                      (request.resource.data.tenantId == uid() || request.resource.data.userId == uid())
                    );
      allow update: if isAuth() && isActive() && (
                      isAdmin() ||
                      (isTechnician() && (
                        (request.resource.data.status == 'COMPLETED' && 
                         resource.data.hasBeforePhoto == true && 
                         resource.data.hasAfterPhoto == true) ||
                        (request.resource.data.status != 'COMPLETED')
                      )) ||
                      (isTenant() && (resource.data.tenantId == uid() || resource.data.userId == uid())) ||
                      isOwner()
                    );
      allow delete: if false;
    }

    match /maintenanceTickets/{ticketId} {
      allow read: if isAuth() && isActive() && (
                    isAdmin() ||
                    isOwner() ||
                    (isTechnician() && (resource.data.technicianAssigned == uid() || resource.data.assignedTechnician == uid())) ||
                    (isTenant() && (resource.data.tenantId == uid() || resource.data.userId == uid()))
                  );
      allow create: if isAuth() && isActive();
      allow update: if isAuth() && isActive() && (
                      isAdmin() ||
                      (isTechnician() && (resource.data.technicianAssigned == uid() || resource.data.assignedTechnician == uid())) ||
                      (isTenant() && (resource.data.tenantId == uid() || resource.data.userId == uid())) ||
                      isOwner()
                    );
      allow delete: if false;
    }

    // ─── 4. MOVE-OUT REQUESTS ────────────────────────────────────────────────
    match /move_out_requests/{requestId} {
      allow create: if isAuth() && isActive();
      allow read:   if isAuth() && isActive() && (
                      isAdmin() || isOwner() ||
                      (isTenant() && resource.data.tenantId == uid())
                    );
      allow update: if isAuth() && isActive() && (isAdmin() || isOwner());
      allow delete: if false;
    }

    // ─── 5. CONTRACTS ────────────────────────────────────────────────────────
    match /contracts/{contractId} {
      allow read:   if isAuth() && isActive() && (
                      isAdmin() ||
                      (isOwner() && resource.data.ownerId == uid())
                    );
      allow create: if isAuth() && isActive() && (
                      isAdmin() || (
                        isOwner() && 
                        request.resource.data.ownerId == uid() &&
                        request.resource.data.paymentVerified == false
                      )
                    );
      allow update: if isAuth() && isActive() && (
                      isAdmin() || (
                        isOwner() && 
                        resource.data.ownerId == uid() &&
                        request.resource.data.paymentVerified == resource.data.paymentVerified &&
                        request.resource.data.status == resource.data.status
                      )
                    );
      allow delete: if false;
    }

    // ─── 6. BILLING EVENTS ───────────────────────────────────────────────────
    match /billingEvents/{billingId} {
      allow read: if isAuth() && isActive() && (
                    isAdmin() ||
                    (isOwner() && get(/databases/$(database)/documents/contracts/$(resource.data.contractId)).data.ownerId == uid())
                  );
      allow write: if false;
    }

    // ─── 7. PROFITABILITY / FINANCIAL LEDGERS ───────────────────────────────
    match /profitability/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    match /financial_ledgers/{ledgerId} {
      allow read:  if isAuth() && isActive() && (
                     isAdmin() ||
                     (isOwner() && resource.data.ownerId == uid())
                   );
      allow write: if false;
    }

    // ─── 8. TECHNICIANS ──────────────────────────────────────────────────────
    match /technicians/{techId} {
      allow read:  if isAuth() && isActive() && (isAdmin() || uid() == techId);
      allow write: if isAdmin() || uid() == techId;
    }

    // ─── 9. PPM SCHEDULES ────────────────────────────────────────────────────
    match /ppmSchedules/{ppmId} {
      allow read:  if isAuth() && isActive();
      allow write: if isAdmin();
    }

    // ─── 10. INSTITUTIONAL AUDIT (AuditShield™) ─────────────────────────────
    match /governanceAudit/{auditId} {
      allow read:   if isAuth() && (isAdmin() || isOwner()); 
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /aiQueryLogs/{queryId} {
      allow read:   if isAuth() && (isAdmin() || (isOwner() && resource.data.ownerId == uid()));
      allow create: if false;
    }

    // ─── 11. KYC & SECURE CUSTODY (BIN-SECURE™) ──────────────────────────────
    match /kycCases/{kycCaseId} {
      allow read:   if isAuth() && (isAdmin() || resource.data.ownerId == uid());
      allow create: if isAuth() && request.resource.data.ownerId == uid();
      allow update: if isAuth() && (isAdmin() || resource.data.ownerId == uid());
      allow delete: if false;
    }

    // ─── 12. TELEMETRY (BIN-LIVE™) ──────────────────────────────────────────
    match /technicianTelemetry/{techId} {
      allow read:   if isAuth() && (isAdmin() || uid() == techId);
      allow create, update: if false;
    }

    match /technicianTelemetryHistory/{packetId} {
      allow read:   if isAdmin();
      allow write:  if false;
    }

    // ─── 13. PORTFOLIO METRICS ──────────────────────────────────────────────
    match /portfolioMetrics/{metricId} {
      allow read:   if isAuth() && (isAdmin() || isOwner());
      allow write:  if false;
    }

    // ─── 14. PUBLIC VERIFICATION (Sovereign Integration) ──────────────────
    match /invoice_registry/{hash} {
      allow get: if true; 
      allow list: if isAdmin();
    }

    match /certificates/{certId} {
      allow get: if true;
      allow list: if isAdmin() || isOwner();
    }

    // ─── 15. CONVERSION TELEMETRY (V1.12) ──────────────────────────────────
    match /analytics_events/{eventId} {
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    // ─── 16. INTUITIVE INTAKE VAULT (V1.15) ────────────────────────────────
    match /intake_submissions/{intakeId} {
      allow create: if request.resource.data.status in ['PENDING', 'PENDING_REVIEW'];
      allow read, update, delete: if isAdmin();
    }

    // ─── CATCH-ALL: Admin can read anything not explicitly covered ───────────
    match /{document=**} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }
  }
}
