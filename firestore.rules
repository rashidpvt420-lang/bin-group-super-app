rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath());
    }

    function userDoc() {
      return get(userPath()).data;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function emailMatches(value) {
      return signedIn() && authEmail() != null && value != null && value == authEmail();
    }

    function hasRole(roles) {
      return signedIn() && (
        request.auth.token.role in roles ||
        request.auth.token.userRole in roles ||
        request.auth.token.primaryRole in roles ||
        (hasUserDoc() && userDoc().role in roles)
      );
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.isAdmin == true ||
        request.auth.token.ceo == true ||
        request.auth.token.manager == true ||
        request.auth.token.operations_admin == true ||
        request.auth.token.finance_admin == true ||
        request.auth.token.hr_admin == true ||
        request.auth.token.support_admin == true ||
        request.auth.token.role in ['admin', 'ceo', 'super_admin', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin'] ||
        request.auth.token.userRole in ['admin', 'ceo', 'super_admin', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin'] ||
        request.auth.token.primaryRole in ['admin', 'ceo', 'super_admin', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().role in ['admin', 'ceo', 'super_admin', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin'])
      );
    }

    function hasPermission(permission) {
      return hasUserDoc() && userDoc().permissions[permission] == true;
    }

    function safeOwnerProfileUpdate() {
      return signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid','email','displayName','name','phone','mobile','photoURL','language',
          'billingContact','notificationPreferences','fcmTokens','pushEnabled','pushUpdatedAt',
          'updatedAt','lastLoginAt','pdplCompliance','gpsConsent','onboardingComplete'
        ]) &&
        (!('status' in request.resource.data) || request.resource.data.status == resource.data.status) &&
        (!('activeContractId' in request.resource.data) || request.resource.data.activeContractId == resource.data.activeContractId) &&
        (!('dashboardUnlocked' in request.resource.data) || request.resource.data.dashboardUnlocked == resource.data.dashboardUnlocked) &&
        (!('paymentVerified' in request.resource.data) || request.resource.data.paymentVerified == resource.data.paymentVerified) &&
        (!('adminNotes' in request.resource.data) || request.resource.data.adminNotes == resource.data.adminNotes) &&
        (!('permissions' in request.resource.data) || request.resource.data.permissions == resource.data.permissions);
    }

    function isOwnerId(ownerId) {
      return signedIn() && ownerId != null && ownerId == request.auth.uid;
    }

    function isTenantId(tenantId) {
      return signedIn() && tenantId != null && tenantId == request.auth.uid;
    }

    function isTechnicianId(techId) {
      return signedIn() && techId != null && techId == request.auth.uid;
    }

    function owns(data) {
      return isOwnerId(data.ownerId) || isOwnerId(data.ownerUid) || isOwnerId(data.authUid) || isOwnerId(data.userId) || isOwnerId(data.createdBy) || isOwnerId(data.createdByUid);
    }

    function tenantOwns(data) {
      return isTenantId(data.tenantId) || isTenantId(data.tenantUid) || isTenantId(data.authUid) || isTenantId(data.userId) || isTenantId(data.createdByUid);
    }

    function techOwns(data) {
      return isTechnicianId(data.assignedTechnicianId) || isTechnicianId(data.technicianId) || isTechnicianId(data.techId);
    }

    function emailOwns(data) {
      return emailMatches(data.email) || emailMatches(data.ownerEmail) || emailMatches(data.tenantEmail) || emailMatches(data.recipientEmail) || emailMatches(data.contactEmail);
    }

    function ownerCanRead(data) {
      return signedIn() && (owns(data) || emailOwns(data));
    }

    function participantCanRead(data) {
      return isAdmin() || ownerCanRead(data) || tenantOwns(data) || techOwns(data);
    }

    function ownerDraftCreate(data) {
      return signedIn() && owns(data) &&
        (!('status' in data) || data.status in ['draft', 'quote_generated', 'contract_selected', 'payment_pending', 'pending_admin_approval', 'pending_approval']) &&
        (!('paymentVerified' in data) || data.paymentVerified == false) &&
        (!('adminApproved' in data) || data.adminApproved == false) &&
        (!('approved' in data) || data.approved == false) &&
        (!('contractActivated' in data) || data.contractActivated == false) &&
        (!('unlocksDashboard' in data) || data.unlocksDashboard == false);
    }

    function paymentDraftCreate(data) {
      return signedIn() && (owns(data) || tenantOwns(data) || data.payerId == request.auth.uid || data.userId == request.auth.uid) &&
        (!('status' in data) || data.status in ['draft', 'payment_pending', 'pending', 'PENDING_PAYMENT', 'PENDING_ADMIN_PAYMENT_VERIFICATION']) &&
        (!('paymentVerified' in data) || data.paymentVerified == false) &&
        (!('approved' in data) || data.approved == false) &&
        (!('contractActivated' in data) || data.contractActivated == false) &&
        (!('unlocksDashboard' in data) || data.unlocksDashboard == false);
    }

    function safeOwnerContractUpdate() {
      return signedIn() && owns(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'signedAt', 'updatedAt']) &&
        (!('paymentVerified' in request.resource.data) || request.resource.data.paymentVerified == resource.data.paymentVerified) &&
        (!('status' in request.resource.data) || !(request.resource.data.status in ['active', 'ACTIVE']));
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId || emailOwns(resource.data);
      allow create: if signedIn() && request.auth.uid == userId && request.resource.data.role in ['owner', 'tenant', 'technician', 'broker'];
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId && request.resource.data.role == resource.data.role && (!('permissions' in request.resource.data) || request.resource.data.permissions == resource.data.permissions) && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == resource.data.isAdmin));
      allow delete: if isAdmin();
      match /fcmTokens/{tokenId} {
        allow read, write: if isAdmin() || request.auth.uid == userId;
      }
    }

    match /owners/{ownerId} {
      allow read: if isOwner(ownerId) || emailOwns(resource.data) || isAdmin() || hasPermission('canManageTenants');
      allow create: if isAdmin() || hasPermission('canManageTenants') || (isOwner(ownerId) && safeOwnerProfileUpdate());
      allow update: if isAdmin() || hasPermission('canManageTenants') || (isOwner(ownerId) && safeOwnerProfileUpdate());
      allow delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /tenants/{tenantId} {
      allow read: if isAdmin() || participantCanRead(resource.data) || request.auth.uid == tenantId;
      allow create, update, delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /technicians/{techId} {
      allow read: if isAdmin() || hasPermission('canManageTechnicians') || request.auth.uid == techId;
      allow create, delete: if isAdmin() || hasPermission('canManageTechnicians');
      allow update: if isAdmin() || hasPermission('canManageTechnicians') || (request.auth.uid == techId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentLocation','lastLocation','locationUpdatedAt','activeTicketId','isTracking','isOnDuty','onDuty','dutyStatus','shiftStartedAt','shiftEndedAt','lastSeenAt','updatedAt']));
    }

    match /properties/{propertyId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data) || tenantOwns(resource.data) || techOwns(resource.data);
      allow create: if isAdmin() || hasPermission('canManageProperties') || ownerDraftCreate(request.resource.data);
      allow update: if isAdmin() || hasPermission('canManageProperties') || (owns(resource.data) && request.resource.data.ownerId == resource.data.ownerId && (!('status' in request.resource.data) || request.resource.data.status != 'active'));
      allow delete: if isAdmin();
    }

    match /properties_pending/{propertyId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data);
      allow create, update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /units/{unitId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data) || tenantOwns(resource.data);
      allow write: if isAdmin() || hasPermission('canManageProperties');
    }

    match /propertyPassports/{passportId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data) || tenantOwns(resource.data) || techOwns(resource.data);
      allow create, update: if isAdmin() || hasPermission('canManageProperties') || ownerDraftCreate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if participantCanRead(resource.data) || hasPermission('canManageContracts');
      allow create: if isAdmin() || hasPermission('canManageContracts') || ownerDraftCreate(request.resource.data);
      allow update, delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /contracts/{contractId} {
      allow read: if participantCanRead(resource.data) || hasPermission('canManageContracts');
      allow create: if isAdmin() || hasPermission('canManageContracts') || ownerDraftCreate(request.resource.data);
      allow update: if isAdmin() || hasPermission('canManageContracts') || safeOwnerContractUpdate();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if participantCanRead(resource.data) || resource.data.payerId == request.auth.uid || hasPermission('canManageContracts');
      allow create: if isAdmin() || hasPermission('canManageContracts') || paymentDraftCreate(request.resource.data);
      allow update, delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /payment_transactions/{paymentId} {
      allow read: if participantCanRead(resource.data) || resource.data.payerId == request.auth.uid || hasPermission('canManageContracts');
      allow create: if isAdmin() || hasPermission('canManageContracts') || paymentDraftCreate(request.resource.data);
      allow update, delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /invoices/{invoiceId} {
      allow read: if participantCanRead(resource.data) || resource.data.payerId == request.auth.uid || hasPermission('canViewPayments');
      allow write: if isAdmin() || hasPermission('canManageContracts') || hasPermission('canVerifyPayments');
    }

    match /tickets/{ticketId} {
      allow read: if participantCanRead(resource.data) || hasPermission('canDispatchJobs');
      allow create: if isAdmin() || hasPermission('canDispatchJobs') || ownerDraftCreate(request.resource.data) || tenantOwns(request.resource.data);
      allow update: if isAdmin() || hasPermission('canDispatchJobs') || (tenantOwns(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','rating','feedback','tenantApproved','rejectionReason','closedAt','updatedAt'])) || (techOwns(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','techNotes','technicianNotes','materialsUsed','actualCost','completedAt','beforePhotoUrl','afterPhotoUrl','signatureUrl','notes','tenantApprovalRequired','updatedAt','startedAt','arrivedAt','onTheWayAt','waitingPartsAt','escalatedAt','completedPendingApprovalAt','beforePhotos','afterPhotos','evidencePhotos','proofPhotos','completionPhotos','technicianLocation','technicianLocationUpdatedAt','trackingStatus','dispatchStatus']));
      allow delete: if isAdmin();
    }

    match /maintenanceTickets/{ticketId} {
      allow read: if participantCanRead(resource.data) || hasPermission('canDispatchJobs');
      allow create: if isAdmin() || hasPermission('canDispatchJobs') || ownerDraftCreate(request.resource.data) || tenantOwns(request.resource.data);
      allow update: if isAdmin() || hasPermission('canDispatchJobs') || (tenantOwns(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','rating','feedback','tenantApproved','rejectionReason','closedAt','updatedAt'])) || (techOwns(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','techNotes','technicianNotes','materialsUsed','actualCost','completedAt','beforePhotoUrl','afterPhotoUrl','signatureUrl','notes','tenantApprovalRequired','updatedAt','startedAt','arrivedAt','onTheWayAt','waitingPartsAt','escalatedAt','completedPendingApprovalAt','beforePhotos','afterPhotos','evidencePhotos','proofPhotos','completionPhotos','technicianLocation','technicianLocationUpdatedAt','trackingStatus','dispatchStatus','assignedTechnicianId','technicianId','acceptedAt','assignedTechnicianName','assignedTechnicianPhone','assignedTechnicianAvatar','technicianSpecialty']));
      allow delete: if isAdmin();
      match /messages/{messageId} {
        allow read, create: if signedIn();
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /workOrders/{workOrderId} {
      allow read: if participantCanRead(resource.data) || hasPermission('canDispatchJobs');
      allow create, update: if isAdmin() || hasPermission('canDispatchJobs') || techOwns(resource.data);
      allow delete: if isAdmin();
    }

    match /addons/{addonId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /documents/{documentId} {
      allow read: if participantCanRead(resource.data) || hasPermission('canManageProperties');
      allow create: if isAdmin() || hasPermission('canManageProperties') || participantCanRead(request.resource.data);
      allow update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /notifications/{notifId} {
      allow read: if isAdmin() || resource.data.recipientId == request.auth.uid || resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAdmin() || resource.data.recipientId == request.auth.uid || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /auditLogs/{auditId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || resource.data.actorId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /audit_logs/{auditId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || resource.data.actorId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /intake_submissions/{intakeId} {
      allow read: if isAdmin() || ownerCanRead(resource.data);
      allow create: if signedIn() && (request.resource.data.ownerUid == request.auth.uid || request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerEmail == request.auth.token.email);
      allow update: if isAdmin() || ownerCanRead(resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if settingId == 'companyProfile' || isAdmin();
      allow write: if isAdmin() || hasPermission('canManageCompanyProfile');
    }

    match /leases/{leaseId} {
      allow read: if participantCanRead(resource.data) || hasPermission('canManageTenants');
      allow write: if isAdmin() || hasPermission('canManageTenants');
    }

    match /tenant_ledger/{ledgerId} {
      allow read: if participantCanRead(resource.data);
      allow write: if isAdmin();
    }

    match /occupancies/{occupancyId} {
      allow read: if participantCanRead(resource.data);
      allow write: if isAdmin() || owns(request.resource.data);
    }

    match /tenant_invitations/{inviteId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.ownerUid == request.auth.uid || resource.data.tenantUid == request.auth.uid || resource.data.tenantEmail == request.auth.token.email));
      allow write: if isAdmin() || (signedIn() && (request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerUid == request.auth.uid));
    }

    match /tenantInvitations/{inviteId} {
      allow read: if isAdmin() || ownerCanRead(resource.data) || emailMatches(resource.data.tenantEmail);
      allow write: if isAdmin() || owns(request.resource.data);
    }

    match /propertyReporters/{reporterId} {
      allow read: if isAdmin() || ownerCanRead(resource.data) || resource.data.reporterUid == request.auth.uid || emailMatches(resource.data.reporterEmail);
      allow create, update: if isAdmin() || owns(request.resource.data) || owns(resource.data);
      allow delete: if isAdmin();
    }

    match /design_requests/{requestId} {
      allow read: if participantCanRead(resource.data);
      allow create: if participantCanRead(request.resource.data) && (!('paymentStatus' in request.resource.data) || request.resource.data.paymentStatus in ['NOT_STARTED','PENDING']);
      allow update: if isAdmin() || hasPermission('canManageProperties') || participantCanRead(resource.data);
      allow delete: if isAdmin();
    }

    match /design_quotes/{quoteId} {
      allow read: if participantCanRead(resource.data);
      allow create: if participantCanRead(request.resource.data);
      allow update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /design_concepts/{conceptId} {
      allow read: if participantCanRead(resource.data);
      allow create: if participantCanRead(request.resource.data);
      allow update, delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /design_approvals/{approvalId} {
      allow read: if participantCanRead(resource.data);
      allow create: if participantCanRead(request.resource.data);
      allow update, delete: if isAdmin() || hasPermission('canManageProperties') || participantCanRead(resource.data);
    }

    match /design_payments/{paymentId} {
      allow read: if participantCanRead(resource.data);
      allow create: if paymentDraftCreate(request.resource.data);
      allow update, delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /brokerReferrals/{referralId} {
      allow read: if isAdmin() || resource.data.brokerId == request.auth.uid || resource.data.brokerUid == request.auth.uid;
      allow create: if signedIn() && (request.resource.data.brokerId == request.auth.uid || request.resource.data.brokerUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /broker_commissions/{commissionId} {
      allow read: if isAdmin() || resource.data.brokerId == request.auth.uid || resource.data.brokerUid == request.auth.uid;
      allow write: if isAdmin();
    }

    match /commissions/{commissionId} {
      allow read: if isAdmin() || resource.data.brokerId == request.auth.uid || resource.data.brokerUid == request.auth.uid;
      allow write: if isAdmin();
    }

    match /gatePasses/{passId} {
      allow read, write: if isAdmin() || tenantOwns(resource.data) || tenantOwns(request.resource.data);
    }

    match /amenityBookings/{bookingId} {
      allow read, write: if isAdmin() || tenantOwns(resource.data) || tenantOwns(request.resource.data);
    }

    match /hrProfiles/{profileId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || request.auth.uid == profileId;
      allow write: if isAdmin() || hasPermission('canManageStaff');
    }

    match /attendanceLogs/{logId} {
      allow read: if isAdmin() || hasPermission('canViewAuditLogs') || resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /hrRequests/{requestId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || hasPermission('canManageStaff');
    }

    match /salaryBenchmarks/{benchmarkId} {
      allow read: if isAdmin() || hasPermission('canManageStaff');
      allow write: if isAdmin() || hasPermission('canManageStaff');
    }

    match /salaryHistory/{historyId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || resource.data.uid == request.auth.uid;
      allow create: if isAdmin() || hasPermission('canManageStaff');
      allow update, delete: if isAdmin();
    }

    match /staffRequests/{requestId} {
      allow read: if isAdmin()
        || hasPermission('canManageStaff')
        || resource.data.uid == request.auth.uid
        || resource.data.userId == request.auth.uid
        || resource.data.technicianId == request.auth.uid;

      allow create: if signedIn() && (
        isAdmin()
        || hasPermission('canManageStaff')
        || request.resource.data.uid == request.auth.uid
        || request.resource.data.userId == request.auth.uid
        || request.resource.data.technicianId == request.auth.uid
      );

      allow update, delete: if isAdmin() || hasPermission('canManageStaff');
    }

    match /staffAgreements/{staffId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || request.auth.uid == staffId;
      allow create: if isAdmin() || hasPermission('canManageStaff');

      allow update: if isAdmin()
        || hasPermission('canManageStaff')
        || (
          request.auth.uid == staffId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'acceptedAt',
            'acceptedBy',
            'acceptanceMethod',
            'updatedAt'
          ])
        );

      allow delete: if isAdmin();
    }

    match /staffMoodCheckins/{checkinId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || hasPermission('canManageStaff');
    }

    match /hrAiConversations/{conversationId} {
      allow read: if isAdmin() || hasPermission('canManageStaff') || resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || hasPermission('canManageStaff');
    }

    match /binGptEngineerCommands/{commandId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
