rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    function adminProfileGrantsAccess() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ceo == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin'] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userRole in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin'] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.primaryRole in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin']
      );
    }

    function isAdmin() {
      return signedIn() && (
        ('admin' in request.auth.token && request.auth.token.admin == true) ||
        ('isAdmin' in request.auth.token && request.auth.token.isAdmin == true) ||
        ('superAdmin' in request.auth.token && request.auth.token.superAdmin == true) ||
        ('super_admin' in request.auth.token && request.auth.token.super_admin == true) ||
        ('ceo' in request.auth.token && request.auth.token.ceo == true) ||
        ('manager' in request.auth.token && request.auth.token.manager == true) ||
        ('role' in request.auth.token && request.auth.token.role in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin']) ||
        ('userRole' in request.auth.token && request.auth.token.userRole in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin']) ||
        ('primaryRole' in request.auth.token && request.auth.token.primaryRole in ['admin', 'super_admin', 'ceo', 'manager', 'operations_admin', 'finance_admin', 'hr_admin', 'support_admin']) ||
        adminProfileGrantsAccess()
      );
    }

    function isHr() {
      return isAdmin() || (signedIn() && (
        ('role' in request.auth.token && request.auth.token.role in ['hr_admin', 'hr_manager', 'hr_staff']) ||
        ('userRole' in request.auth.token && request.auth.token.userRole in ['hr_admin', 'hr_manager', 'hr_staff']) ||
        ('primaryRole' in request.auth.token && request.auth.token.primaryRole in ['hr_admin', 'hr_manager', 'hr_staff'])
      ));
    }

    function isHrManagerTier() {
      return isAdmin() || (signedIn() && (
        ('role' in request.auth.token && request.auth.token.role in ['hr_admin', 'hr_manager']) ||
        ('userRole' in request.auth.token && request.auth.token.userRole in ['hr_admin', 'hr_manager']) ||
        ('primaryRole' in request.auth.token && request.auth.token.primaryRole in ['hr_admin', 'hr_manager'])
      ));
    }

    function isFinance() {
      return isAdmin() || (signedIn() && (
        ('role' in request.auth.token && request.auth.token.role in ['finance_admin', 'finance_staff', 'account_manager']) ||
        ('userRole' in request.auth.token && request.auth.token.userRole in ['finance_admin', 'finance_staff', 'account_manager']) ||
        ('primaryRole' in request.auth.token && request.auth.token.primaryRole in ['finance_admin', 'finance_staff', 'account_manager'])
      ));
    }

    function isOps() {
      return isAdmin() || (signedIn() && (
        ('role' in request.auth.token && request.auth.token.role in ['operations_admin', 'operations_manager', 'dispatcher']) ||
        ('userRole' in request.auth.token && request.auth.token.userRole in ['operations_admin', 'operations_manager', 'dispatcher']) ||
        ('primaryRole' in request.auth.token && request.auth.token.primaryRole in ['operations_admin', 'operations_manager', 'dispatcher'])
      ));
    }

    function hasPermission(permission) {
      return isAdmin() || (signedIn() && 'permissions' in request.auth.token && permission in request.auth.token.permissions && request.auth.token.permissions[permission] == true);
    }

    function authEmail() { return (signedIn() && 'email' in request.auth.token) ? request.auth.token.email : null; }
    function emailMatches(value) { return signedIn() && authEmail() != null && value != null && value == authEmail(); }
    function isOwnerId(ownerId) { return signedIn() && ownerId != null && ownerId == request.auth.uid; }
    function isOwner(ownerId) { return isOwnerId(ownerId); }
    function isTenantId(tenantId) { return signedIn() && tenantId != null && tenantId == request.auth.uid; }
    function isTechnicianId(techId) { return signedIn() && techId != null && techId == request.auth.uid; }

    function owns(data) {
      return isOwnerId(data.ownerId) || isOwnerId(data.ownerUid) || isOwnerId(data.authUid) || isOwnerId(data.userId) || isOwnerId(data.createdBy) || isOwnerId(data.createdByUid);
    }

    function tenantOwns(data) {
      return isTenantId(data.tenantId) || isTenantId(data.tenantUid) || isTenantId(data.authUid) || isTenantId(data.userId) || isTenantId(data.createdByUid);
    }

    function techOwns(data) {
      return isTechnicianId(data.assignedTechnicianId) || isTechnicianId(data.technicianId) || isTechnicianId(data.techId);
    }

    function brokerOwns(data) {
      return signedIn() && (
        data.brokerId == request.auth.uid ||
        data.brokerUid == request.auth.uid ||
        data.userId == request.auth.uid ||
        data.createdByUid == request.auth.uid
      );
    }



    function emailOwns(data) {
      return emailMatches(data.email) ||
        emailMatches(data.ownerEmail) ||
        emailMatches(data.tenantEmail) ||
        emailMatches(data.technicianEmail) ||
        emailMatches(data.staffEmail) ||
        emailMatches(data.brokerEmail) ||
        emailMatches(data.recipientEmail) ||
        emailMatches(data.contactEmail);
    }

    function ownerCanRead(data) { return signedIn() && (owns(data) || emailOwns(data)); }
    function staffCanRead(data) { return signedIn() && (techOwns(data) || isTechnicianId(data.uid) || isTechnicianId(data.userId) || isTechnicianId(data.technicianId) || isTechnicianId(data.staffId) || emailOwns(data)); }
    function staffCanCreate(data) { return signedIn() && (isTechnicianId(data.uid) || isTechnicianId(data.userId) || isTechnicianId(data.technicianId) || isTechnicianId(data.staffId) || emailOwns(data)); }
    function isConfidentialRequest(data) {
      return ('requestType' in data && data.requestType == 'manager_issue') || ('category' in data && data.category == 'confidential');
    }
 review/deployed-hosting-state


 main
    function isTechnicianActor() {
      return signedIn() && (
        ('role' in request.auth.token && request.auth.token.role == 'technician') ||
        ('userRole' in request.auth.token && request.auth.token.userRole == 'technician') ||
        ('primaryRole' in request.auth.token && request.auth.token.primaryRole == 'technician') ||
        exists(/databases/$(database)/documents/technicians/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'technician')
      );
    }

    function hasTechnicianDispatchAuthority() {
      return signedIn() && (
        request.auth.token.role in ['admin', 'super_admin', 'operations_admin', 'operations_manager', 'dispatcher', 'technician'] ||
        request.auth.token.userRole in ['admin', 'super_admin', 'operations_admin', 'operations_manager', 'dispatcher', 'technician'] ||
        request.auth.token.primaryRole in ['admin', 'super_admin', 'operations_admin', 'operations_manager', 'dispatcher', 'technician']
      );
    }
 review/deployed-hosting-state


 main
    function openMissionAvailable(data) { return data.assignedTechnicianId == null && data.status in ['OPEN', 'open', 'emergency_submitted']; }
    function openMissionPoolRead(data) { return hasTechnicianDispatchAuthority() && openMissionAvailable(data); }
    function participantCanRead(data) { return isAdmin() || ownerCanRead(data) || tenantOwns(data) || techOwns(data) || brokerOwns(data); }

    function staffRequestCreate(data) {
      return staffCanCreate(data) &&
        (!('status' in data) || data.status in ['pending_hr_review', 'pending_finance_review', 'submitted']) &&
        (!('paperless' in data) || data.paperless == true) &&
        (!('payrollApproved' in data) || data.payrollApproved == false) &&
        (!('hrApproved' in data) || data.hrApproved == false) &&
        (!('approved' in data) || data.approved == false);
    }

    function ownerDraftCreate(data) {
      return signedIn() && owns(data) &&
        (!('status' in data) || data.status in ['draft', 'quote_generated', 'contract_selected', 'payment_pending', 'pending_admin_approval', 'pending_approval']) &&
        (!('paymentVerified' in data) || data.paymentVerified == false) &&
        (!('adminApproved' in data) || data.adminApproved == false) &&
        (!('approved' in data) || data.approved == false) &&
        (!('contractActivated' in data) || data.contractActivated == false) &&
        (!('unlocksDashboard' in data) || data.unlocksDashboard == false);
    }

    function paymentDraftCreate(data) {
      return signedIn() && (owns(data) || tenantOwns(data) || data.payerId == request.auth.uid || data.userId == request.auth.uid) &&
        (!('status' in data) || data.status in ['draft', 'payment_pending', 'pending', 'PENDING_PAYMENT', 'PENDING_ADMIN_PAYMENT_VERIFICATION']) &&
        (!('paymentVerified' in data) || data.paymentVerified == false) &&
        (!('approved' in data) || data.approved == false) &&
        (!('contractActivated' in data) || data.contractActivated == false) &&
        (!('unlocksDashboard' in data) || data.unlocksDashboard == false);
    }

    function safeOwnerContractUpdate() {
      return signedIn() && owns(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'signedAt', 'updatedAt']) &&
        (!('paymentVerified' in request.resource.data) || request.resource.data.paymentVerified == resource.data.paymentVerified) &&
        (!('status' in request.resource.data) || !(request.resource.data.status in ['active', 'ACTIVE']));
    }

    function safeTenantEvidenceUpdate() {
      return signedIn() && tenantOwns(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photos', 'primaryPhotoUrl', 'tenantPhotos', 'evidenceStatus', 'evidenceUploadedAt', 'evidenceUploadError', 'updatedAt']) &&
        (!('evidenceStatus' in request.resource.data) || request.resource.data.evidenceStatus in ['PENDING_TENANT_UPLOAD', 'TENANT_EVIDENCE_UPLOADED', 'TENANT_EVIDENCE_UPLOAD_FAILED']);
    }

    function canCreateTenantBoundTicket(data) {
      return signedIn() &&
        tenantOwns(data) &&
        data.keys().hasAll(['unitId', 'propertyId']) &&
        data.unitId is string &&
        data.propertyId is string &&
        data.unitId.size() > 0 &&
        exists(/databases/$(database)/documents/units/$(data.unitId)) &&
        (
          isTenantId(get(/databases/$(database)/documents/units/$(data.unitId)).data.tenantId) ||
          isTenantId(get(/databases/$(database)/documents/units/$(data.unitId)).data.tenantUid) ||
          isTenantId(get(/databases/$(database)/documents/units/$(data.unitId)).data.userId) ||
          isTenantId(get(/databases/$(database)/documents/units/$(data.unitId)).data.authUid) ||
          emailMatches(get(/databases/$(database)/documents/units/$(data.unitId)).data.tenantEmail)
        ) &&
        data.propertyId == get(/databases/$(database)/documents/units/$(data.unitId)).data.propertyId &&
        (!('ownerId' in data) || !('ownerId' in get(/databases/$(database)/documents/units/$(data.unitId)).data) || data.ownerId == get(/databases/$(database)/documents/units/$(data.unitId)).data.ownerId) &&
        (!('ownerUid' in data) || !('ownerUid' in get(/databases/$(database)/documents/units/$(data.unitId)).data) || data.ownerUid == get(/databases/$(database)/documents/units/$(data.unitId)).data.ownerUid);
    }

    function safeTechnicianTicketUpdate() {
      return signedIn() && techOwns(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt',
          'technicianNotes',
          'techNotes',
          'workNotes',
          'startedAt',
          'completedAt',
          'arrivedAt',
          'beforePhotos',
          'afterPhotos',
          'proofPhotos',
          'completionPhotos',
          'evidenceStatus',
          'resolutionSummary',
          'materialsUsed'
        ]) &&
        (!('assignedTechnicianId' in request.resource.data) || request.resource.data.assignedTechnicianId == resource.data.assignedTechnicianId) &&
        (!('technicianId' in request.resource.data) || request.resource.data.technicianId == resource.data.technicianId) &&
        (!('techId' in request.resource.data) || request.resource.data.techId == resource.data.techId) &&
        (!('priority' in request.resource.data) || request.resource.data.priority == resource.data.priority) &&
        (!('paymentVerified' in request.resource.data) || request.resource.data.paymentVerified == resource.data.paymentVerified) &&
        (!('status' in request.resource.data) || request.resource.data.status in ['ASSIGNED', 'IN_PROGRESS', 'ARRIVED', 'COMPLETED', 'RESOLVED', 'assigned', 'in_progress', 'arrived', 'completed']);
    }

    function safeOpenMissionClaim() {
      return hasTechnicianDispatchAuthority() && openMissionAvailable(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedTechnicianId', 'technicianId', 'techId', 'status', 'updatedAt', 'assignedAt']) &&
        (!('assignedTechnicianId' in request.resource.data) || request.resource.data.assignedTechnicianId == request.auth.uid) &&
        (!('technicianId' in request.resource.data) || request.resource.data.technicianId == request.auth.uid) &&
        (!('techId' in request.resource.data) || request.resource.data.techId == request.auth.uid) &&
        (!('status' in request.resource.data) || request.resource.data.status in ['ASSIGNED', 'assigned', 'IN_PROGRESS', 'in_progress']);
    }

    function canAccessMaintenanceTicket(ticketId) {
      return signedIn() && exists(/databases/$(database)/documents/maintenanceTickets/$(ticketId)) && participantCanRead(get(/databases/$(database)/documents/maintenanceTickets/$(ticketId)).data);
    }

    function safeTicketMessageCreate(ticketId) {
      return canAccessMaintenanceTicket(ticketId) &&
        (!('senderId' in request.resource.data) || request.resource.data.senderId == request.auth.uid) &&
        (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid) &&
        (!('createdBy' in request.resource.data) || request.resource.data.createdBy == request.auth.uid);
    }

    function safeUserBootstrapCreate(data, userId) {
      return signedIn() && request.auth.uid == userId &&
        request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'phoneNumber',
          'status',
          'createdAt',
          'updatedAt',
          'lastLoginAt',
          'platform',
          'isStandalone',
          'userAgent',
          'fcmTokens',
          'notificationPreferences',
          'language',
          'preferences'
        ]) &&
        (!('uid' in data) || data.uid == request.auth.uid) &&
        (!('email' in data) || data.email == request.auth.token.email) &&
        (!('status' in data) || data.status == 'role_required');
    }

    function safeUserSelfUpdate(userId) {
      return signedIn() && request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'photoURL',
          'phone',
          'phoneNumber',
          'mobile',
          'preferredLanguage',
          'language',
          'lang',
          'legalAcceptedAt',
          'legalAcceptedAtClient',
          'pdplCompliance',
          'gpsConsent',
          'legalAcceptedVersion',
          'termsAcceptedAt',
          'termsVersion',
          'privacyAcceptedAt',
          'notificationPreferences',
          'fcmTokens',
          'platform',
          'isStandalone',
          'userAgent',
          'lastLoginAt',
          'lastSeenAt',
          'pushEnabled',
          'pushPermission',
          'deviceInfo',
          'onboardingLastSeenAt',
          'dutyStatus',
          'onDuty',
          'updatedAt'
        ]) &&
        (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
        (!('userRole' in request.resource.data) || request.resource.data.userRole == resource.data.userRole) &&
        (!('primaryRole' in request.resource.data) || request.resource.data.primaryRole == resource.data.primaryRole) &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == resource.data.isAdmin) &&
        (!('admin' in request.resource.data) || request.resource.data.admin == resource.data.admin) &&
        (!('superAdmin' in request.resource.data) || request.resource.data.superAdmin == resource.data.superAdmin) &&
        (!('super_admin' in request.resource.data) || request.resource.data.super_admin == resource.data.super_admin) &&
        (!('permissions' in request.resource.data) || request.resource.data.permissions == resource.data.permissions) &&
        (!('status' in request.resource.data) || request.resource.data.status == resource.data.status) &&
        (!('onboardingComplete' in request.resource.data) || request.resource.data.onboardingComplete == resource.data.onboardingComplete) &&
        (!('propertyId' in request.resource.data) || request.resource.data.propertyId == resource.data.propertyId) &&
        (!('unitId' in request.resource.data) || request.resource.data.unitId == resource.data.unitId);
    }

    function safeOwnerProfileCreate(data, ownerId) {
      return signedIn() && request.auth.uid == ownerId &&
        (!('role' in data) || data.role == 'owner') &&
        (!('status' in data) || !(data.status in ['ACTIVE','active'])) &&
        (!('dashboardUnlocked' in data)) &&
        (!('paymentVerified' in data));
    }

    function safeOwnerProfileUpdate() {
      return signedIn() &&
        (!('status' in request.resource.data) || request.resource.data.status == resource.data.status) &&
        (!('dashboardUnlocked' in request.resource.data) || request.resource.data.dashboardUnlocked == resource.data.dashboardUnlocked) &&
        (!('paymentVerified' in request.resource.data) || request.resource.data.paymentVerified == resource.data.paymentVerified);
    }

    function ownsOnboardingProof(data) {
      return signedIn() && (
        data.ownerUid == request.auth.uid ||
        data.ownerId == request.auth.uid ||
        data.userId == request.auth.uid ||
        data.createdByUid == request.auth.uid ||
        data.email == request.auth.token.email ||
        data.ownerEmail == request.auth.token.email
      );
    }

    function safeOnboardingProofCreate(data) {
      return ownsOnboardingProof(data) &&
        (!('verified' in data) || data.verified == false) &&
        (!('approved' in data) || data.approved == false) &&
        (!('adminApproved' in data) || data.adminApproved == false) &&
        (!('paymentVerified' in data) || data.paymentVerified == false);
    }

    match /users/{userId} {
      allow read: if isAdmin() || isHr() || isFinance() || isOps() || (signedIn() && request.auth.uid == userId) || emailOwns(resource.data) ||
                  (signedIn() && request.auth.uid != userId && resource.data.role == 'tenant' &&
                   ((resource.data.get('ownerId', '') != '' && resource.data.get('ownerId', '') == request.auth.uid) ||
                    (resource.data.get('ownerEmail', '') != '' && resource.data.get('ownerEmail', '') == request.auth.token.get('email', ''))));
      allow create: if isAdmin() || safeUserBootstrapCreate(request.resource.data, userId);
      allow update: if isAdmin() || safeUserSelfUpdate(userId);
      allow delete: if isAdmin();
      match /{document=**} {
        allow read: if isAdmin() || isHr() || (signedIn() && request.auth.uid == userId);
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /owners/{ownerId} {
      allow read: if isOwner(ownerId) || emailOwns(resource.data) || isAdmin() || hasPermission('canManageTenants');
      allow create: if isAdmin() || hasPermission('canManageTenants') || safeOwnerProfileCreate(request.resource.data, ownerId);
      allow update: if isAdmin() || hasPermission('canManageTenants') || (isOwner(ownerId) && safeOwnerProfileUpdate());
      allow delete: if isAdmin() || hasPermission('canManageTenants');
    }

    match /tenants/{tenantId} {
      allow read: if isAdmin() || participantCanRead(resource.data) || (signedIn() && request.auth.uid == tenantId);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /technicians/{techId} {
      allow read: if isAdmin() || isHr() || isOps() || hasPermission('canManageTechnicians') || (signedIn() && request.auth.uid == techId) || emailOwns(resource.data);
      allow create: if isAdmin() || isHr() || isOps() || hasPermission('canManageTechnicians');
      allow update: if isAdmin() || isHr() || isOps() || hasPermission('canManageTechnicians') || (signedIn() && request.auth.uid == techId);
      allow delete: if isAdmin() || hasPermission('canManageTechnicians');
    }

    match /properties/{propertyId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data) || tenantOwns(resource.data) || (isTechnicianActor() && techOwns(resource.data));
      allow create: if isAdmin() || hasPermission('canManageProperties') || ownerDraftCreate(request.resource.data);
      allow update: if isAdmin() || hasPermission('canManageProperties') || (owns(resource.data) && request.resource.data.ownerId == resource.data.ownerId && (!('status' in request.resource.data) || !(request.resource.data.status in ['active', 'ACTIVE'])));
      allow delete: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if isAdmin() || hasPermission('canManageProperties') || ownerCanRead(resource.data) || tenantOwns(resource.data) || emailOwns(resource.data);
      allow create: if isAdmin() || hasPermission('canManageProperties');
      allow update: if isAdmin() || hasPermission('canManageProperties');
      allow delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /contracts/{contractId} {
      allow read: if participantCanRead(resource.data) || emailOwns(resource.data) || hasPermission('canManageContracts');
      allow create: if isAdmin() || hasPermission('canManageContracts') || ownerDraftCreate(request.resource.data);
      allow update: if isAdmin() || hasPermission('canManageContracts') || safeOwnerContractUpdate();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if participantCanRead(resource.data) || (signedIn() && resource.data.payerId == request.auth.uid) || hasPermission('canManageContracts');
      allow create: if isAdmin() || hasPermission('canManageContracts') || paymentDraftCreate(request.resource.data);
      allow update: if isAdmin() || hasPermission('canManageContracts');
      allow delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /payment_transactions/{paymentId} {
      allow read: if participantCanRead(resource.data) || (signedIn() && resource.data.payerId == request.auth.uid) || hasPermission('canManageContracts');
      allow create: if isAdmin() || hasPermission('canManageContracts') || paymentDraftCreate(request.resource.data);
      allow update: if isAdmin() || hasPermission('canManageContracts');
      allow delete: if isAdmin() || hasPermission('canManageContracts');
    }

    match /tickets/{ticketId} {
      allow read: if participantCanRead(resource.data) || hasPermission('canDispatchJobs');
      allow create: if isAdmin() || hasPermission('canDispatchJobs') || ownerDraftCreate(request.resource.data) || canCreateTenantBoundTicket(request.resource.data);
      allow update: if isAdmin() || hasPermission('canDispatchJobs') || safeTenantEvidenceUpdate() || safeTechnicianTicketUpdate() || safeOpenMissionClaim();
      allow delete: if isAdmin();
    }

    match /maintenanceTickets/{ticketId} {
      allow read: if participantCanRead(resource.data) || openMissionPoolRead(resource.data) || hasPermission('canDispatchJobs');
      allow create: if isAdmin() || hasPermission('canDispatchJobs') || ownerDraftCreate(request.resource.data) || canCreateTenantBoundTicket(request.resource.data);
      allow update: if isAdmin() || hasPermission('canDispatchJobs') || safeTenantEvidenceUpdate() || safeTechnicianTicketUpdate() || safeOpenMissionClaim();
      allow delete: if isAdmin();
      match /messages/{messageId} {
        allow read: if canAccessMaintenanceTicket(ticketId);
        allow create: if safeTicketMessageCreate(ticketId);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /documents/{documentId} {
      allow read: if participantCanRead(resource.data) || emailOwns(resource.data) || hasPermission('canManageProperties');
      allow create: if isAdmin() || hasPermission('canManageProperties') || participantCanRead(request.resource.data);
      allow update: if isAdmin() || hasPermission('canManageProperties');
      allow delete: if isAdmin() || hasPermission('canManageProperties');
    }

    match /intake_submissions/{intakeId} {
      allow read: if isAdmin() || ownerCanRead(resource.data);
      allow create: if signedIn() && (request.resource.data.ownerUid == request.auth.uid || request.resource.data.ownerId == request.auth.uid || request.resource.data.ownerEmail == request.auth.token.email);
      allow update: if isAdmin() || ownerCanRead(resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if settingId == 'companyProfile' || isAdmin();
      allow create: if isAdmin() || hasPermission('canManageCompanyProfile');
      allow update: if isAdmin() || hasPermission('canManageCompanyProfile');
      allow delete: if isAdmin() || hasPermission('canManageCompanyProfile');
    }

    match /systemLogs/{logId} {
      allow read: if isAdmin() || isHr() || (signedIn() && resource.data.type == 'TENANT_NOTICE');
      allow create: if isAdmin() || isHr();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /staffRequests/{requestId} {
      allow read: if isConfidentialRequest(resource.data)
        ? (isHrManagerTier() || staffCanRead(resource.data))
        : (isHr() || isFinance() || isOps() || staffCanRead(resource.data));
      allow create: if isHr() || isFinance() || isOps() || staffRequestCreate(request.resource.data);
      allow update: if isConfidentialRequest(resource.data) ? isHrManagerTier() : (isHr() || isFinance() || isOps());
      allow delete: if isHr() || isAdmin();
    }

    match /hrAiConversations/{caseId} {
      allow read: if isConfidentialRequest(resource.data)
        ? (isHrManagerTier() || staffCanRead(resource.data))
        : (isHr() || staffCanRead(resource.data));
      allow create: if isHr() || staffRequestCreate(request.resource.data);
      allow update: if isConfidentialRequest(resource.data) ? isHrManagerTier() : isHr();
      allow delete: if isHr();
    }

    match /staffMoodCheckins/{checkinId} {
      allow read: if isHr() || staffCanRead(resource.data);
      allow create: if isHr() || staffCanCreate(request.resource.data);
      allow update: if isHr();
      allow delete: if isHr();
    }

    match /staffDocuments/{documentId} {
      allow read: if isHr() || isFinance() || staffCanRead(resource.data);
      allow create: if isHr() || staffRequestCreate(request.resource.data);
      allow update: if isHr();
      allow delete: if isHr();
    }

    match /staffPayslips/{payslipId} {
      allow read: if isHr() || isFinance() || staffCanRead(resource.data);
      allow create: if isHr() || isFinance();
      allow update: if isHr() || isFinance();
      allow delete: if isHr() || isFinance();
    }

    match /hrProfiles/{profileId} {
      allow read: if isHr() || isFinance() || isOps() || (signedIn() && request.auth.uid == profileId) || staffCanRead(resource.data);
      allow create: if isHr();
      allow update: if isHr();
      allow delete: if isHr();
    }

    match /attendanceLogs/{logId} {
      allow read: if isHr() || isFinance() || isOps() || staffCanRead(resource.data);
      allow create: if isHr() || isOps() || staffRequestCreate(request.resource.data);
      allow update: if isHr() || isOps();
      allow delete: if isHr() || isOps();
    }

    match /overtimeRequests/{requestId} {
      allow read: if isHr() || isFinance() || isOps() || staffCanRead(resource.data);
      allow create: if isHr() || isOps() || staffRequestCreate(request.resource.data);
      allow update: if isHr() || isFinance() || isOps();
      allow delete: if isHr() || isFinance() || isOps();
    }

    match /staffAssets/{assetId} {
      allow read: if isHr() || isOps() || staffCanRead(resource.data);
      allow create: if isHr() || isOps();
      allow update: if isHr() || isOps();
      allow delete: if isHr() || isOps();
    }

    match /staffLetters/{letterId} {
      allow read: if isHr() || staffCanRead(resource.data);
      allow create: if isHr();
      allow update: if isHr();
      allow delete: if isHr();
    }

    match /staffComplaints/{complaintId} {
      allow read: if isHrManagerTier() || staffCanRead(resource.data);
      allow create: if isHrManagerTier() || staffRequestCreate(request.resource.data);
      allow update: if isHrManagerTier();
      allow delete: if isHrManagerTier();
    }

    match /staffTraining/{trainingId} {
      allow read: if isHr() || isOps() || staffCanRead(resource.data);
      allow create: if isHr() || isOps();
      allow update: if isHr() || isOps();
      allow delete: if isHr() || isOps();
    }

    match /staffAgreements/{agreementId} {
      allow read: if isHr() || staffCanRead(resource.data) || (signedIn() && request.auth.uid == agreementId);
      allow create: if isHr();
      allow update: if isHr() || (signedIn() && request.auth.uid == agreementId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','acceptedAt','acceptedBy','acceptanceDate']));
      allow delete: if isHr();
    }

    match /salaryHistory/{historyId} {
      allow read: if isHr() || isFinance();
      allow create: if isHr() || isFinance();
      allow update: if isHr() || isFinance();
      allow delete: if isHr() || isFinance();
    }

    match /staffComplianceAlerts/{alertId} {
      allow read: if isHr() || isFinance() || staffCanRead(resource.data);
      allow create: if isHr() || isFinance();
      allow update: if isHr() || isFinance();
      allow delete: if isHr() || isFinance();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin() || isHr();
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin() || isHr();
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.recipientId == request.auth.uid || resource.data.userId == request.auth.uid));
      allow create: if isAdmin() || (signedIn() && request.resource.data.recipientId == request.auth.uid && (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid) && (!('createdBy' in request.resource.data) || request.resource.data.createdBy == request.auth.uid));
      allow update: if isAdmin() || (signedIn() && (resource.data.recipientId == request.auth.uid || resource.data.userId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /staff_roster/{staffId} {
      allow read: if isAdmin() || isHr() || staffCanRead(resource.data);
      allow create: if isAdmin() || isHr();
      allow update: if isAdmin() || isHr();
      allow delete: if isAdmin() || isHr();
    }

    match /hr_staff/{staffId} {
      allow read: if isAdmin() || isHr() || staffCanRead(resource.data);
      allow create: if isAdmin() || isHr();
      allow update: if isAdmin() || isHr();
      allow delete: if isAdmin() || isHr();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isHr() || staffCanRead(resource.data);
      allow create: if isAdmin() || isHr();
      allow update: if isAdmin() || isHr();
      allow delete: if isAdmin() || isHr();
